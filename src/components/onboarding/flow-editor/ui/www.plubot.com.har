xt;background-clip:text;color:transparent;text-shadow:0 0 10px rgba(0,224,255,.5);font-family:Orbitron,sans-serif;font-size:1.2rem;font-weight:600;margin-top:1.5rem;display:inline-block;transition:text-shadow .3s ease,transform .3s ease;position:relative;text-decoration:none}.quantum-footer .opinion-link:hover{text-shadow:0 0 15px rgba(0,224,255,.7),0 0 20px rgba(255,0,255,.5);transform:translateY(-2px)}.quantum-footer .opinion-link:after{content:\"\";position:absolute;bottom:-2px;left:0;width:0;height:1px;background:linear-gradient(90deg,#00e0ff,#f0f);transition:width .3s ease}.quantum-footer .opinion-link:hover:after{width:100%}:root{--color-blue: #4285F4;--color-green: #34A853;--color-red: #EA4335;--color-gray: #9AA0A6}.sync-indicator{display:flex;flex-direction:column;background-color:#fffffff2;border-radius:8px;box-shadow:0 2px 8px #0000001a;padding:10px;margin:8px 0;cursor:pointer;transition:all .3s ease;border-left:3px solid var(--status-color, var(--color-gray));max-width:300px;overflow:hidden}.sync-indicator:hover{box-shadow:0 4px 12px #00000026}.sync-indicator.expanded{box-shadow:0 6px 16px #0003}.sync-indicator-basic{display:flex;align-items:center;gap:10px}.sync-icon{font-size:18px;display:inline-flex;align-items:center;justify-content:center}.sync-status-text{font-size:14px;font-weight:500;color:#333}.sync-details{margin-top:12px;padding-top:12px;border-top:1px solid #eee;font-size:13px;overflow:hidden}.sync-detail-item{display:flex;justify-content:space-between;margin-bottom:8px;color:#555}.sync-errors{margin-top:10px}.sync-errors h4{color:var(--color-red);margin:0 0 8px;font-size:13px}.sync-errors ul{margin:0;padding-left:20px;font-size:12px;color:#666}.sync-controls{margin-top:12px;display:flex;justify-content:center}.sync-now-btn{background-color:var(--color-blue);color:#fff;border:none;border-radius:4px;padding:6px 12px;font-size:13px;cursor:pointer;transition:background-color .2s}.sync-now-btn:hover{background-color:#3367d6}.sync-now-btn:disabled{