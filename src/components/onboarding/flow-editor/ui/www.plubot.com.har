            "text": ".cosmic-call{background:transparent;text-align:center;padding:5rem 1.5rem;position:relative;z-index:1}.cosmic-call .call-overlay{max-width:1000px;margin:0 auto}.cosmic-call h2{font-size:3rem;color:#00e0ff;text-shadow:0 0 15px rgba(0,224,255,.8),0 0 25px rgba(0,224,255,.6),0 0 35px rgba(0,224,255,.4);animation:glowFadeIn 1.5s ease-in-out forwards;font-family:Orbitron,sans-serif}.cosmic-call .call-cta{display:flex;gap:1.5rem;justify-content:center;margin-top:2rem}.cosmic-call .hero-button{background:transparent;border:3px solid #00e0ff;color:#00e0ff;padding:1rem 2.5rem;border-radius:10px;font-size:1.2rem;font-family:Orbitron,sans-serif;text-shadow:0 0 15px rgba(0,224,255,1);box-shadow:0 0 25px #00e0ff,0 0 35px #00e0ffb3;transition:all .3s ease;animation:pulse 2s infinite ease-in-out,slideIn 1s ease-out forwards;animation-delay:.5s;opacity:0}.cosmic-call .hero-button.secondary{background:transparent;border:3px solid #ff00ff;color:#f0f;box-shadow:0 0 25px #f0f,0 0 35px #ff00ffb3;text-shadow:0 0 15px rgba(255,0,255,1);animation:pulseSecondary 2s infinite ease-in-out,slideIn 1s ease-out forwards;animation-delay:.8s;opacity:0}.cosmic-call .hero-button:hover{transform:scale(1.1);background-color:#00e0ff;color:#000;box-shadow:0 0 40px #00e0ff,0 0 50px #00e0ffcc}.cosmic-call .hero-button.secondary:hover{background:#f0f;color:#000;box-shadow:0 0 40px #f0f,0 0 50px #f0fc;transform:scale(1.1)}@keyframes glowFadeIn{0%{opacity:0;text-shadow:none}50%{opacity:.5;text-shadow:0 0 15px rgba(0,224,255,.4),0 0 25px rgba(0,224,255,.2)}to{opacity:1;text-shadow:0 0 15px rgba(0,224,255,.8),0 0 25px rgba(0,224,255,.6),0 0 35px rgba(0,224,255,.4)}}@keyframes slideIn{0%{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}@keyframes pulse{0%{box-shadow:0 0 25px #00e0ff,0 0 35px #00e0ffb3;text-shadow:0 0 15px rgba(0,224,255,1)}50%{box-shadow:0 0 40px #00e0ff,0 0 50px #00e0ffcc;text-shadow:0 0 20px rgba(0,224,255,1)}to{box-shadow:0 0 25px #00e0ff,0 0 35p