            "text": ".plubot-universe{background:var(--bg-image) no-repeat center center fixed;background-size:cover;width:100%;max-width:none;min-height:70vh;color:#fff;text-align:center;padding:3rem 2rem;position:relative;z-index:1;box-sizing:border-box;margin:0;margin-top:3rem;display:flex;justify-content:center;align-items:center}.plubot-universe .universe-content{max-width:800px;margin:0 auto;font-family:Orbitron,sans-serif;position:relative;z-index:2}.plubot-universe .universe-content h2{font-size:2.5rem;margin-bottom:1rem;color:#00e0ff;text-shadow:0 0 10px rgba(0,224,255,.8),0 0 20px rgba(0,224,255,.6),0 0 30px rgba(0,224,255,.4);background:#00000080;padding:.5rem 1rem;border-radius:8px;animation:pulseGlow 2s ease-in-out infinite}.plubot-universe .universe-content p{font-size:1.2rem;margin-bottom:1.5rem;color:#d0d0ff;text-shadow:0 0 8px rgba(0,224,255,.6),0 0 15px rgba(0,224,255,.4);background:#00000080;padding:.5rem 1rem;border-radius:8px;animation:flicker 3s ease-in-out infinite}.plubot-universe .universe-button{display:inline-block;padding:.8rem 1.5rem;background:#00e0ff;color:#000;font-family:Orbitron,sans-serif;font-size:1rem;text-decoration:none;border-radius:8px;box-shadow:0 0 10px #00e0ffcc,0 0 20px #00e0ff99;animation:pulseGlow 2s ease-in-out infinite;transition:all .3s ease}.plubot-universe .universe-button:hover{background:#00b8d4;box-shadow:0 0 15px #00e0ff,0 0 25px #00e0ffcc;transform:scale(1.05)}@keyframes pulseGlow{0%{text-shadow:0 0 10px rgba(0,224,255,.8),0 0 20px rgba(0,224,255,.6),0 0 30px rgba(0,224,255,.4)}50%{text-shadow:0 0 20px rgba(0,224,255,1),0 0 30px rgba(0,224,255,.8),0 0 40px rgba(0,224,255,.6)}to{text-shadow:0 0 10px rgba(0,224,255,.8),0 0 20px rgba(0,224,255,.6),0 0 30px rgba(0,224,255,.4)}}@keyframes flicker{0%{opacity:1;text-shadow:0 0 8px rgba(0,224,255,.6),0 0 15px rgba(0,224,255,.4)}50%{opacity:.9;text-shadow:0 0 5px rgba(0,224,255,.4),0 0 10px rgba(0,224,255,.2)}to{opacity:1;text-shadow:0 0 8px rgba(0,224,255,.6),0 0 15px