            "text": "import\"./vendor.CkcL9lYj.js\";import\"./index.DGAzTSCj.js\";import\"./ui.Ds5STbS-.js\";import\"./flow.C2uQ13xg.js\";import\"./services.D5Vlq_We.js\";import\"./utils.D7ATQL4y.js\";class a{constructor(){this.container=null,this.root=null,this.isInitialized=!1}init(){console.log(\"[PerformanceMonitor] Monitor desactivado. Las estadísticas están ahora en el menú de Opciones\"),this.isInitialized=!0}handleKeyPress(o){o.altKey&&o.key===\"p\"&&this.toggleVisibility()}setupPerformanceButton(){new MutationObserver(r=>{r.forEach(s=>{if(s.addedNodes.length){const i=document.querySelector(\".performance-indicator\");i&&!i.hasAttribute(\"data-monitor-initialized\")&&(i.setAttribute(\"data-monitor-initialized\",\"true\"),i.addEventListener(\"click\",()=>{this.toggleVisibility()}),console.log(\"[PerformanceMonitor] Botón de rendimiento configurado\"))}})}).observe(document.body,{childList:!0,subtree:!0})}toggleVisibility(){if(!this.container)return;const o=this.container.style.display!==\"none\";this.container.style.display=o?\"none\":\"block\",console.log(`[PerformanceMonitor] ${o?\"Ocultado\":\"Mostrado\"}`)}}const e=new a;document.addEventListener(\"DOMContentLoaded\",()=>{e.init()});function l(){document.readyState===\"complete\"?t():window.addEventListener(\"load\",()=>{t()})}function t(){return window.location.pathname.includes(\"/flow-editor\")||document.querySelector(\".flow-editor-container\")!==null?(e.init(),console.log(\"[initPerformanceMonitor] Monitor inicializado en el editor de flujos\")):console.log(\"[initPerformanceMonitor] No estamos en el editor, no se inicializa el monitor\"),console.log(\"[initPerformanceMonitor] Monitor de rendimiento configurado para inicializarse\"),e}l();export{l as initPerformanceMonitor,e as performanceMonitor};\n//# sourceMappingURL=initPerformanceMonitor.BkxqBNMV.js.map\n"
