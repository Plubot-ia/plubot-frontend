o-text{color:#ffca28;text-shadow:0 0 20px rgba(255,202,40,.8);transform:scale(1.05)}.header .logo:hover .logo-text:after{width:100%}.header .logo-image{width:59px;height:59px;min-width:59px;min-height:59px;object-fit:contain;margin-left:-1rem;z-index:1;position:relative;opacity:0;transition:opacity .3s ease}.header .logo-image.loaded{opacity:1;animation:header-pulseGlow 3s ease-in-out infinite,header-slightRotate 10s linear infinite;filter:drop-shadow(0 0 20px #00f0ff);transition:transform .4s ease,filter .4s ease,opacity .3s ease}.header .logo-image:after{content:\"\";position:absolute;top:-10%;left:-10%;width:120%;height:120%;border-radius:50%;background:radial-gradient(circle,rgba(0,224,255,.4) 0%,transparent 70%);animation:header-auraScan 4s ease-in-out infinite;z-index:-1;pointer-events:none}.header .nav-links{display:flex;list-style:none;gap:1.5rem;margin:0;padding:0 .5rem 0 0;align-items:center;transition:max-height .4s ease,opacity .3s ease}.header .nav-links li a{display:flex;align-items:center;gap:.4rem;color:#00e0ff;font-family:Inter,sans-serif;font-weight:400;font-size:1rem;text-transform:capitalize;letter-spacing:1.5px;position:relative;padding:.3rem 0;line-height:1.2;white-space:nowrap;text-shadow:0 0 10px rgba(0,224,255,.7);text-decoration:none}.header .nav-links li a.active{text-decoration:none}.header .nav-links li a .nav-icon{font-size:1rem;font-weight:400;text-shadow:0 0 10px rgba(0,224,255,.7)}.header .nav-links li a:after{content:\"\";position:absolute;width:0;height:2px;bottom:-4px;left:0;background:linear-gradient(90deg,#00e0ff,#0f8);box-shadow:0 0 8px #00e0ffcc;transition:width .4s ease}.header .nav-links li a:hover{color:#fff;text-shadow:0 0 15px #00e0ff,0 0 25px #00e0ff}.header .nav-links li a:hover:after{width:100%}.header .auth-section{display:flex;align-items:center;gap:1rem;transition:all .3s ease}.header .auth-button{padding:.5rem 1.2rem;border:2px solid #00e0ff;border-radius:20px;color:#00e0ff;font-family:Inter,sans-serif;font-weight:400;font-size:.75rem;text-transform:capitalize;letter-spacing:1.5px;transition:all .3s cubic-bezier(.25,.8,.25,1);position:relative;overflow:hidden;text-align:center;white-space:nowrap;min-width:160px;text-shadow:0 0 10px rgba(0,224,255,.7);text-decoration:none;z-index:1}.header .auth-button:before{content:\"\";position:absolute;top:0;left:-150%;width:150%;height:100%;background:linear-gradient(90deg,transparent,rgba(0,224,255,.3),transparent);border-radius:20px;transition:left .5s ease;z-index:-1}.header .auth-button.glowing{background:linear-gradient(45deg,#00e0ff,#0f8);color:#000;box-shadow:0 0 15px #00e0ffcc}.header .auth-button:hover{background:linear-gradient(45deg,#00e0ff,#0f8);color:#000;box-shadow:0 0 25px #00e0ff;transform:translateY(-3px) scale(1.03);letter-spacing:2px;border-color:#fff;text-shadow:0 0 8px rgba(0,0,0,.5)}.header .auth-button:hover:before{left:150%}.header .auth-button[data-tooltip]:after{content:attr(data-tooltip);position:absolute;top:-30px;left:50%;transform:translate(-50%);background:#1a1a1a;color:#00e0ff;padding:.3rem .6rem;border-radius:5px;font-size:.7rem;opacity:0;transition:opacity .3s ease;pointer-events:none}.header .auth-button:hover[data-tooltip]:after{opacity:1}.header .user-info{display:flex;align-items:center;gap:.5rem;color:#fff;font-family:Inter,sans-serif;font-size:.7rem}.header .user-level,.header .plu-coins{background:#1a1a1a;padding:.15rem .4rem;border-radius:12px;box-shadow:0 0 8px #00e0ff80;display:flex;align-items:center;gap:.15rem;position:relative;transition:box-shadow .3s ease}.header .user-level:hover,.header .plu-coins:hover{box-shadow:0 0 15px #00e0ffcc}.header .menu-toggle{display:none;background:none;border:none;color:#00e0ff;font-size:1.4rem;cursor:pointer;transition:color .3s ease,transform .3s ease;padding:.5rem;min-width:44px;min-height:44px}.header .menu-toggle:hover{color:#ffca28;transform:scale(1.1)}.header .user-profile{position:relative}.header .profile-icon{width:40px;height:40px;background:linear-gradient(45deg,#00e0ff,#0f8);color:#0a0e2f;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:Inter,sans-serif;font-size:1.2rem;font-weight:600;cursor:pointer;transition:all .3s ease;box-shadow:0 0 10px #00e0ff80}.header .profile-icon:hover{background:linear-gradient(45deg,#ffca28,#ffb300);box-shadow:0 0 15px #ffca28cc;transform:scale(1.05)}.header .profile-dropdown{position:absolute;top:50px;right:0;background:#0a1128f2;backdrop-filter:blur(5px);border:1px solid rgba(0,224,255,.3);border-radius:8px;box-shadow:0 4px 20px #00e0ff33;padding:15px;z-index:99;width:220px;color:#fff;font-family:Inter,sans-serif;animation:header-fadeIn .3s ease-in-out}.header .profile-info p{margin:5px 0;font-size:.9rem;color:#fff;text-shadow:0 0 5px rgba(0,224,255,.3)}.header .profile-stats p{margin:5px 0;font-size:.9rem;color:#00e0ff;text-shadow:0 0 5px rgba(0,224,255,.3)}.header .profile-link{display:block;margin:10px 0;color:#00e0ff;font-size:.9rem;text-decoration:none;transition:color .3s ease,text-shadow .3s ease}.header .profile-link:hover{color:#ffca28;text-shadow:0 0 10px rgba(255,202,40,.8)}.header .logout-btn{background:linear-gradient(45deg,#f26666,#ff4040);color:#fff;border:none;padding:8px 12px;border-radius:5px;cursor:pointer;width:100%;text-align:center;font-family:Inter,sans-serif;font-size:.9rem;transition:all .3s ease;box-shadow:0 0 8px #f2666680}.header .logout-btn:hover{background:linear-gradient(45deg,#ffca28,#ffb300);box-shadow:0 0 15px #ffca28cc}.header .nav-links li a.tight-text{letter-spacing:.5px;word-spacing:-2px}.header .nav-icon{margin-right:6px;vertical-align:middle;color:#00f0ff;transition:transform .2s ease,filter .2s ease}.header .nav-icon:hover{transform:scale(1.2);filter:drop-shadow(0 0 5px #00f0ff)}@media (max-width: 1366px){.header .navbar{padding:0 1.2rem}.header .logo-text{font-size:1.3rem}.header .logo{gap:.1rem}.header .logo-image{width:52px;height:52px;min-width:52px;min-height:52px;margin-left:-.8rem}.header .na