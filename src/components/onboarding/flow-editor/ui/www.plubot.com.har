            "mimeType": "text/plain",
            "text": ".plubot-forge{padding:4rem 2rem;position:relative;background:transparent;z-index:1;text-align:center}.plubot-forge .forge-header{text-align:center;margin-bottom:3.5rem}.plubot-forge .forge-header h2{font-family:Inter,sans-serif;font-size:2.8rem;color:#00e0ff;text-shadow:0 0 20px rgba(0,224,255,.8),0 0 40px rgba(0,224,255,.4);margin-bottom:1rem;animation:neonGlow 2s ease-in-out infinite}.plubot-forge .forge-subtitle{font-family:Inter,sans-serif;font-size:1.2rem;color:#e0e0e0;max-width:700px;margin:0 auto;opacity:.9;text-shadow:0 0 10px rgba(0,224,255,.3)}.plubot-forge .forge-container{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:2rem;max-width:1200px;margin:0 auto}.plubot-forge .forge-card{background:#00000080;border:2px solid transparent;border-radius:12px;padding:2rem;text-align:center;position:relative;overflow:hidden;backdrop-filter:blur(5px);transition:border .3s ease}.plubot-forge .forge-card:hover{border:2px solid #00e0ff;box-shadow:0 0 30px #00e0ff99}.plubot-forge .card-hologram{position:relative;z-index:1}.plubot-forge .card-hologram:before{content:\"\";position:absolute;top:0;left:0;width:100%;height:100%;background:linear-gradient(45deg,transparent,rgba(0,224,255,.2),transparent);opacity:0;transition:opacity .4s ease}.plubot-forge .forge-card:hover .card-hologram:before{opacity:1}.plubot-forge .holo-icon{display:block;width:70px;height:70px;margin:0 auto 1.5rem;background-size:contain;background-repeat:no-repeat;background-position:center;filter:drop-shadow(0 0 15px rgba(0,224,255,.8));animation:iconFloat 3s ease-in-out infinite}.plubot-forge .holo-icon.nucleus{background-image:url(/assets/img/nucleus-icon.png)}.plubot-forge .holo-icon.essence{background-image:url(/assets/img/essence-icon.png)}.plubot-forge .holo-icon.galaxy{background-image:url(/assets/img/galaxy-icon.png)}.plubot-forge .forge-card h3{font-family:Inter,sans-serif;font-size:1.7rem;color:#00e0ff;text-shadow:0 0 12px rgba(0,224,255,.6);margin-bottom:.8rem}.plubot-forge .forge-card p{font-family:Inter,sans-serif;font-size:1rem;color:#e0e0e0;opacity:.9}.plubot-forge .forge-cta{display:inline-flex;align-items:center;justify-content:center;margin:2.5rem auto 0;padding:1.2rem 3.5rem;border:none;border-radius:50px;background:linear-gradient(90deg,#00e0ff,#00b4d8);color:#000;font-family:Inter,sans-serif;font-size:1.3rem;font-weight:700;text-transform:uppercase;text-decoration:none;position:relative;overflow:hidden;box-shadow:0 0 20px #00e0ffb3;cursor:pointer;transition:all .3s ease;min-width:200px;text-align:center}.plubot-forge .forge-cta:before{content:\"\";position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.4),transparent);transition:left .6s ease;z-index:1}.plubot-forge .forge-cta:hover:before{left:100%}.plubot-forge .forge-cta:hover{box-shadow:0 0 40px #00e0ff;transform:translateY(-2px)}.plubot-forge .forge-cta:active{transform:translateY(0)}@keyframes neonGlow{0%{text-shadow:0 0 20px rgba(0,224,255,.8),0 0 40px rgba(0,224,255,.4)}50%{text-shadow:0 0 30px rgba(0,224,255,1),0 0 60px rgba(0,224,255,.6)}to{text-shadow:0 0 20px rgba(0,224,255,.8),0 0 40px rgba(0,224,255,.4)}}@keyframes iconFloat{0%{transform:translateY(0);filter:drop-shadow(0 0 15px rgba(0,224,255,.8))}50%{transform:translateY(-10px);filter:drop-shadow(0 0 25px rgba(0,224,255,1))}to{transform:translateY(0);filter:drop-shadow(0 0 15px rgba(0,224,255,.8))}}@media (max-width: 768px){.plubot-forge{padding:3rem 1.5rem}.plubot-forge .forge-header h2{font-size:2.2rem}.plubot-forge .forge-subtitle{font-size:1rem;max-width:90%}.plubot-forge .forge-container{grid-template-columns:1fr;gap:1.5rem}.plubot-forge .forge-card{padding:1.8rem}.plubot-forge .forge-cta{padding:1rem 2.5rem;font-size:1.1rem}}@media (max-width: 480px){.plubot-forge .forge-header h2{font-size:1.8rem}.plubot-forge .forge-subtitle{font-size:.9rem}.plubot-forge .forge-card h3{font-size:1.4rem}.plubot-forge .forge-card p{font-size:.9rem}.plubot-forge .holo-icon{width:50px;height:50px}.plubot-forge .forge-cta{padding:.8rem 2rem;font-size:1rem}}\n"
