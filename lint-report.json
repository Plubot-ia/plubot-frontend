,"endColumn":18},{"ruleId":"react/prop-types","severity":1,"message":"'importData' is missing in props validation","line":16,"column":3,"nodeType":"Property","messageId":"missingPropType","endLine":16,"endColumn":13},{"ruleId":"react/prop-types","severity":1,"message":"'setImportData' is missing in props validation","line":17,"column":3,"nodeType":"Property","messageId":"missingPropType","endLine":17,"endColumn":16},{"ruleId":"react/prop-types","severity":1,"message":"'setExportMode' is missing in props validation","line":18,"column":3,"nodeType":"Property","messageId":"missingPropType","endLine":18,"endColumn":16},{"ruleId":"react/prop-types","severity":1,"message":"'setByteMessage' is missing in props validation","line":19,"column":3,"nodeType":"Property","messageId":"missingPropType","endLine":19,"endColumn":41},{"ruleId":"react/prop-types","severity":1,"message":"'onClose' is missing in props validation","line":20,"column":3,"nodeType":"Property","messageId":"missingPropType","endLine":20,"endColumn":10},{"ruleId":"react/prop-types","severity":1,"message":"'plubotData.name' is missing in props validation","line":53,"column":35,"nodeType":"Identifier","messageId":"missingPropType","endLine":53,"endColumn":39},{"ruleId":"react/prop-types","severity":1,"message":"'nodes.length' is missing in props validation","line":55,"column":28,"nodeType":"Identifier","messageId":"missingPropType","endLine":55,"endColumn":34},{"ruleId":"react/prop-types","severity":1,"message":"'edges.length' is missing in props validation","line":56,"column":28,"nodeType":"Identifier","messageId":"missingPropType","endLine":56,"endColumn":34},{"ruleId":"react/prop-types","severity":1,"message":"'nodes.map' is missing in props validation","line":58,"column":22,"nodeType":"Identifier","messageId":"missingPropType","endLine":58,"endColumn":25},{"ruleId":"unicorn/no-null","severity":2,"message":"Use `undefined` instead of `null`.","line":66,"column":53,"nodeType":"Literal","messageId":"error","endLine":66,"endColumn":57,"suggestions":[{"messageId":"replace","fix":{"range":[1746,1750],"text":"undefined"},"data":{},"desc":"Replace `null` with `undefined`."}]},{"ruleId":"react/prop-types","severity":1,"message":"'plubotData.name' is missing in props validation","line":73,"column":46,"nodeType":"Identifier","messageId":"missingPropType","endLine":73,"endColumn":50},{"ruleId":"react/prop-types","severity":1,"message":"'importData.trim' is missing in props validation","line":91,"column":23,"nodeType":"Identifier","messageId":"missingPropType","endLine":91,"endColumn":27},{"ruleId":"no-alert","severity":2,"message":"Unexpected confirm.","line":143,"column":10,"nodeType":"CallExpression","messageId":"unexpected","endLine":147,"endColumn":10},{"ruleId":"prefer-destructuring","severity":2,"message":"Use array destructuring.","line":170,"column":11,"nodeType":"VariableDeclarator","messageId":"preferDestructuring","endLine":170,"endColumn":39},{"ruleId":"unicorn/prevent-abbreviations","severity":1,"message":"Please rename the variable `e`. Suggested names are: `error`, `event_`. A more descriptive name will do too.","line":173,"column":38,"nodeType":"Identifier","messageId":"suggestion","endLine":173,"endColumn":39},{"ruleId":"unicorn/prefer-blob-reading-methods","severity":2,"message":"Prefer `Blob#text()` over `FileReader#readAsText(blob)`.","line":176,"column":12,"nodeType":"Identifier","messageId":"error","endLine":176,"endColumn":22},{"ruleId":"unicorn/prevent-abbreviations","severity":1,"message":"Please rename the variable `e`. Suggested names are: `error`, `event_`. A more descriptive name will do too.","line":238,"column":28,"nodeType":"Identifier","messageId":"suggestion","endLine":238,"endColumn":29}],"suppressedMessages":[],"errorCount":4,"fatalErrorCount":0,"warningCount":23,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React from 'react';\n\nimport './ImportExportModal.css';\n// Importar el contexto global\nimport useGlobalContext from '../../../hooks/useGlobalContext';\n\nconst ImportExportModal = ({\n  nodes,\n  edges,\n  setNodes,\n  setEdges,\n  plubotData,\n  updatePlubotData,\n  exportFormat,\n  setExportFormat,\n  importData,\n  setImportData,\n  setExportMode,\n  setByteMessage: propertySetByteMessage, // Renombramos para evitar conflictos\n  onClose, // Mantener para retrocompatibilidad\n}) => {\n  // Usar el contexto global para notificaciones y gestión de modales\n  const {\n    showNotification,\n    setByteMessage: globalSetByteMessage,\n    closeModal,\n  } = useGlobalContext();\n\n  // Función para mostrar mensajes utilizando múltiples métodos disponibles\n  const notifyMessage = (message, type = 'info') => {\n    // Priorizar el contexto global\n    if (globalSetByteMessage) {\n      globalSetByteMessage(message);\n    }\n\n    // Usar la función de notificación global\n    showNotification(message, type);\n\n    // Usar la prop para retrocompatibilidad\n    if (propertySetByteMessage) {\n      try {\n        propertySetByteMessage(message);\n      } catch {\n        // Silently fail if prop is not a function\n      }\n    }\n  };\n  const exportFlow = () => {\n    try {\n      const flowData = {\n        metadata: {\n          version: '1.0',\n          plubotName: plubotData?.name || 'Unnamed Plubot',\n          createdAt: new Date().toISOString(),\n          nodeCount: nodes.length,\n          edgeCount: edges.length,\n        },\n        nodes: nodes.map((node) => ({\n          ...node,\n          __rf: undefined,\n          dragging: undefined,\n          selected: undefined,\n        })),\n        edges,\n      };\n      const exportString = JSON.stringify(flowData, null, 2);\n      const blob = new Blob([exportString], {\n        type: 'text/plain;charset=utf-8',\n      });\n      const url = URL.createObjectURL(blob);\n      const downloadLink = document.createElement('a');\n      downloadLink.href = url;\n      downloadLink.download = `${plubotData?.name || 'plubot'}_flow_${new Date().toISOString().split('T')[0]}.${exportFormat}`;\n      document.body.append(downloadLink);\n      downloadLink.click();\n      downloadLink.remove();\n      notifyMessage(\n        `¡Flujo exportado con éxito! Se guardó como ${downloadLink.download}`,\n        'success',\n      );\n    } catch {\n      notifyMessage(\n        'Error al exportar el flujo. Por favor, intenta de nuevo.',\n        'error',\n      );\n    }\n  };\n\n  const importFlow = () => {\n    try {\n      if (!importData.trim()) {\n        notifyMessage(\n          'Por favor, ingresa datos de flujo para importar.',\n          'warning',\n        );\n        return;\n      }\n      const parsedData = JSON.parse(importData);\n      if (\n        !parsedData.nodes ||\n        !Array.isArray(parsedData.nodes) ||\n        !parsedData.edges ||\n        !Array.isArray(parsedData.edges)\n      ) {\n        throw new Error(\n          'Formato de datos inválido. El flujo debe contener arrays de nodos y aristas.',\n        );\n      }\n      const hasStart = parsedData.nodes.some((node) => node.type === 'start');\n      const hasMessage = parsedData.nodes.some(\n        (node) => node.type === 'message',\n      );\n      if (!hasStart || !hasMessage) {\n        notifyMessage(\n          'Precaución: El flujo importado puede estar incompleto. Asegúrate de tener nodos de inicio y mensaje.',\n          'warning',\n        );\n      }\n      const validNodes = parsedData.nodes.filter(\n        (node) =>\n          node &&\n          node.id &&\n          node.type &&\n          node.position &&\n          typeof node.position.x === 'number' &&\n          typeof node.position.y === 'number' &&\n          node.data &&\n          typeof node.data.label === 'string',\n      );\n      const validNodeIds = new Set(validNodes.map((node) => node.id));\n      const validEdges = parsedData.edges.filter(\n        (edge) =>\n          edge &&\n          edge.id &&\n          edge.source &&\n          edge.target &&\n          validNodeIds.has(edge.source) &&\n          validNodeIds.has(edge.target),\n      );\n      if (\n        (validNodes.length < parsedData.nodes.length ||\n          validEdges.length < parsedData.edges.length) &&\n        !confirm(\n          `Advertencia: ${parsedData.nodes.length - validNodes.length} nodos y ${\n            parsedData.edges.length - validEdges.length\n          } conexiones son inválidos y serán ignorados. ¿Deseas continuar?`,\n        )\n      ) {\n        return;\n      }\n      setNodes(validNodes);\n      setEdges(validEdges);\n      setExportMode(false);\n      setImportData('');\n      notifyMessage(\n        `¡Flujo importado con éxito! Se cargaron ${validNodes.length} nodos y ${validEdges.length} conexiones.`,\n        'success',\n      );\n      notifyMessage(\n        'Flujo importado con éxito. ¡Bienvenido de vuelta!',\n        'success',\n      );\n      closeModal('importExportModal'); // Cierra el modal al importar con éxito\n    } catch (error) {\n      notifyMessage(`Error al importar el flujo: ${error.message}`, 'error');\n    }\n  };\n\n  const importFromFile = (event) => {\n    const file = event.target.files[0];\n    if (!file) return;\n    const reader = new FileReader();\n    reader.addEventListener('load', (e) => {\n      setImportData(e.target.result);\n    });\n    reader.readAsText(file);\n  };\n\n  return (\n    <div className='ts-import-export-modal'>\n      <div className='ts-modal-content'>\n        <div className='ts-modal-header'>\n          <h3>{importData ? 'Importar Flujo' : 'Exportar Flujo'}</h3>\n          <button\n            onClick={() => {\n              if (closeModal) {\n                closeModal('importExportModal');\n              } else if (typeof onClose === 'function') {\n                onClose();\n              }\n            }}\n            className='ts-close-button'\n          >\n            ✕\n          </button>\n        </div>\n\n        <div className='ts-modal-tabs'>\n          <button\n            className={importData ? '' : 'active'}\n            onClick={() => setImportData('')}\n          >\n            Exportar\n          </button>\n          <button\n            className={importData ? 'active' : ''}\n            onClick={() => setImportData(' ')}\n          >\n            Importar\n          </button>\n        </div>\n\n        {importData ? (\n          <div className='ts-import-section'>\n            <div className='ts-import-options'>\n              <h4>Importar Flujo</h4>\n              <p>\n                Puedes pegar el contenido del flujo directamente o seleccionar\n                un archivo:\n              </p>\n              <div className='ts-file-input-container'>\n                <input\n                  type='file'\n                  accept='.json,.txt'\n                  onChange={importFromFile}\n                  id='flow-file-input'\n                />\n                <label\n                  htmlFor='flow-file-input'\n                  className='ts-file-input-label'\n                >\n                  <i className='fas fa-file-upload' /> Seleccionar archivo\n                </label>\n              </div>\n              <textarea\n                placeholder='Pega aquí el contenido del flujo para importar...'\n                value={importData}\n                onChange={(e) => setImportData(e.target.value)}\n                rows={10}\n                className='ts-import-textarea'\n              />\n            </div>\n            <div className='ts-warning-message'>\n              <i className='fas fa-exclamation-triangle' />\n              <p>\n                La importación reemplazará tu flujo actual. Asegúrate de hacer\n                una copia de seguridad si no quieres perder tu trabajo actual.\n              </p>\n            </div>\n            <div className='ts-import-actions'>\n              <button\n                onClick={() => setImportData('')}\n                className='ts-secondary-button'\n              >\n                Cancelar\n              </button>\n              <button onClick={importFlow} className='ts-primary-button'>\n                <i className='fas fa-file-import' /> Importar Flujo\n              </button>\n            </div>\n          </div>\n        ) : (\n          <div className='ts-export-section'>\n            <div className='ts-export-options'>\n              <h4>Opciones de Exportación</h4>\n              <div className='ts-format-selection'>\n                <label>\n                  <input\n                    type='radio'\n                    name='exportFormat'\n                    value='json'\n                    checked={exportFormat === 'json'}\n                    onChange={() => setExportFormat('json')}\n                  />\n                  JSON\n                </label>\n              </div>\n            </div>\n            <div className='ts-import-actions'>\n              <button onClick={exportFlow} className='ts-primary-button'>\n                <i className='fas fa-download' /> Exportar Flujo\n              </button>\n            </div>\n          </div>\n        )}\n      </div>\n    </div>\n  );\n};\n\nexport default ImportExportModal;\n","usedDeprecatedRules":[{"ruleId":"sonarjs/updated-loop-counter","replacedBy":[]},{"ruleId":"no-new-object","replacedBy":["no-object-constructor"],"info":{"message":"The new rule flags more situations where object literal syntax can be used, and it does not report a problem when the `Object` constructor is invoked with an argument.","url":"https://eslint.org/blog/2023/09/eslint-v8.50.0-released/","deprecatedSince":"8.50.0","availableUntil":null,"replacedBy":[{"rule":{"name":"no-object-constructor","url":"https://eslint.org/docs/rules/no-object-constructor"}}]}}]},{"filePath":"/Users/wolf/Desktop/Plubot/plubot-frontend/src/components/onboarding/modals/SuggestionsModal.jsx","messages":[{"ruleId":"react/prop-types","severity":1,"message":"'suggestions' is missing in p