temporal.\n * Lógica simplificada para manejar una sola notificación a la vez con cierre manual y automático.\n * @param {object} notification - Objeto que contiene el texto y un ID único para forzar re-render.\n */\nconst StatusBubble = ({ notification }) => {\n  const [isVisible, setIsVisible] = useState(false);\n  const [message, setMessage] = useState('');\n  const hideTimer = useRef(null);\n\n  const AUTO_HIDE_DELAY = 5000; // 5 segundos\n\n  // Función para ocultar la burbuja, ya sea manual o automáticamente\n  const hideBubble = useCallback(() => {\n    if (hideTimer.current) {\n      clearTimeout(hideTimer.current);\n      hideTimer.current = null;\n    }\n    setIsVisible(false);\n  }, []);\n\n  useEffect(() => {\n    // Si llega una nueva notificación con texto, la procesamos.\n    if (notification && notification.text) {\n      // Limpiamos cualquier temporizador anterior para evitar cierres prematuros.\n      if (hideTimer.current) {\n        clearTimeout(hideTimer.current);\n      }\n\n      // Mostramos la nueva notificación.\n      setMessage(notification.text);\n      setIsVisible(true);\n\n      // Configuramos un nuevo temporizador para ocultarla automáticamente.\n      hideTimer.current = setTimeout(() => {\n        hideBubble();\n      }, AUTO_HIDE_DELAY);\n    }\n\n    // Cleanup: Asegurarse de limpiar el temporizador si el componente se desmonta.\n    return () => {\n      if (hideTimer.current) {\n        clearTimeout(hideTimer.current);\n      }\n    };\n  }, [notification, hideBubble]); // Dependemos de la notificación y la función de ocultar.\n\n  // Si no es visible, no renderizamos nada.\n  if (!isVisible) {\n    return null;\n  }\n\n  return (\n    <div className='status-bubble'>\n      <div className='status-bubble-content'>\n        {message}\n        <button\n          className='status-bubble-close'\n          onClick={hideBubble} // El botón de cierre ahora llama directamente a hideBubble.\n          aria-label='Cerrar mensaje'\n        >\n          ×\n        </button>\n      </div>\n      <div className='status-bubble-arrow' />\n    </div>\n  );\n};\n\nStatusBubble.propTypes = {\n  notification: PropTypes.shape({\n    text: PropTypes.string.isRequired\n  })\n};\n\nexport default StatusBubble;\n","usedDeprecatedRules":[{"ruleId":"sonarjs/updated-loop-counter","replacedBy":[]},{"ruleId":"no-new-object","replacedBy":["no-object-constructor"],"info":{"message":"The new rule flags more situations where object literal syntax can be used, and it does not report a problem when the `Object` constructor is invoked with an argument.","url":"https://eslint.org/blog/2023/09/eslint-v8.50.0-released/","deprecatedSince":"8.50.0","availableUntil":null,"replacedBy":[{"rule":{"name":"no-object-constructor","url":"https://eslint.org/docs/rules/no-object-constructor"}}]}}]},{"filePath":"/Users/wolf/Desktop/Plubot/plubot-frontend/src/components/onboarding/common/TransparentOverlay.jsx","messages":[{"ruleId":"import/order","severity":1,"message":"`prop-types` import should occur before import of `react`","line":2,"column":1,"nodeType":"ImportDeclaration","endLine":2,"endColumn":36,"fix":{"range":[0,63],"text":"import PropTypes from 'prop-types';\nimport React from 'react';\n"}},{"ruleId":"unicorn/no-null","severity":2,"message":"Use `undefined` instead of `null`.","line":16,"column":12,"nodeType":"Literal","messageId":"error","endLine":16,"endColumn":16,"suggestions":[{"messageId":"remove","fix":{"range":[570,574],"text":""},"data":{},"desc":"Remove `null`."},{"messageId":"replace","fix":{"range":[570,574],"text":"undefined"},"data":{},"desc":"Replace `null` with `undefined`."}]},{"ruleId":"prettier/prettier","severity":2,"message":"Insert `,`","line":28,"column":39,"nodeType":null,"messageId":"insert","endLine":28,"endColumn":39,"fix":{"range":[832,832],"text":","}}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":1,"fixableWarningCount":1,"source":"import React fro