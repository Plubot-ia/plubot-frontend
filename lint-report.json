       nodes: [\n          {\n            id: 'start-1',\n            type: 'start',\n            position: { x: 100, y: 100 },\n            data: { label: 'Inicio' },\n          },\n        ],\n        edges: [],\n      },\n      flowVersions: [],\n    });\n  }, []);\n\n  const contextValue = {\n    currentStep,\n    nextStep,\n    plubotData,\n    updatePlubotData,\n    activeSection,\n    updateActiveSection,\n    resetPlubotCreation,\n  };\n\n  return (\n    <PlubotCreationContext.Provider value={contextValue}>\n      {children}\n    </PlubotCreationContext.Provider>\n  );\n};\n","usedDeprecatedRules":[{"ruleId":"sonarjs/updated-loop-counter","replacedBy":[]},{"ruleId":"no-new-object","replacedBy":["no-object-constructor"],"info":{"message":"The new rule flags more situations where object literal syntax can be used, and it does not report a problem when the `Object` constructor is invoked with an argument.","url":"https://eslint.org/blog/2023/09/eslint-v8.50.0-released/","deprecatedSince":"8.50.0","availableUntil":null,"replacedBy":[{"rule":{"name":"no-object-constructor","url":"https://eslint.org/docs/rules/no-object-constructor"}}]}}]},{"filePath":"/Users/wolf/Desktop/Plubot/plubot-frontend/src/context/PlubotCreationContextObject.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[{"ruleId":"sonarjs/updated-loop-counter","replacedBy":[]},{"ruleId":"no-new-object","replacedBy":["no-object-constructor"],"info":{"message":"The new rule flags more situations where object literal syntax can be used, and it does not report a problem when the `Object` constructor is invoked with an argument.","url":"https://eslint.org/blog/2023/09/eslint-v8.50.0-released/","deprecatedSince":"8.50.0","availableUntil":null,"replacedBy":[{"rule":{"name":"no-object-constructor","url":"https://eslint.org/docs/rules/no-object-constructor"}}]}}]},{"filePath":"/Users/wolf/Desktop/Plubot/plubot-frontend/src/context/SimulationContext.js","messages":[{"ruleId":"unicorn/no-null","severity":2,"message":"Use `undefined` instead of `null`.","line":8,"column":18,"nodeType":"Literal","messageId":"error","endLine":8,"endColumn":22,"suggestions":[{"messageId":"replace","fix":{"range":[205,209],"text":"undefined"},"data":{},"desc":"Replace `null` with `undefined`."}]},{"ruleId":"react/prop-types","severity":1,"message":"'children' is missing in props validation","line":34,"column":38,"nodeType":"Property","messageId":"missingPropType","endLine":34,"endColumn":46}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"// SimulationContext.js\nimport React, { createContext, useContext, useReducer, useEffect } from 'react';\n\nconst SimulationContext = createContext();\n\nconst initialState = {\n  history: [],\n  currentNodeId: null,\n  isTyping: false,\n  userInput: '',\n  simulationActive: false,\n  settings: {\n    language: 'es',\n    theme: 'dark',\n    soundEffects: true,\n  },\n};\n\nfunction simulationReducer(state, action) {\n  switch (action.type) {\n    case 'SET_NODE': {\n      return { ...state, currentNodeId: action.payload };\n    }\n    case 'ADD_MESSAGE': {\n      return { ...state, history: [...state.history, action.payload] };\n    }\n    // Otros casos...\n    default: {\n      return state;\n    }\n  }\n}\n\nexport const SimulationProvider = ({ children }) => {\n  const [state, dispatch] = useReducer(simulationReducer, initialState);\n\n  // Persistencia\n  useEffect(() => {\n    const savedState = localStorage.getItem('simulation-state');\n    if (savedState) {\n      try {\n        dispatch({ type: 'RESTORE_STATE', payload: JSON.parse(savedState) });\n      } catch {}\n    }\n  }, []);\n\n  useEffect(() => {\n    localStorage.setItem('simulation-state', JSON.stringify(state));\n  }, [state]);\n\n  return (\n    <SimulationContext.Provider value={{ state, dispatch }}>\n      {children}\n    </SimulationContext.Provider>\n  );\n};\n\nexport const useSimulation = () => useContext(SimulationContext);\n","usedDeprecatedRules":[{"ruleId":"sonarjs/updated-loop-counter","replacedBy":[]},{"ruleId":"no-new-object","replacedBy":["no-object-constructor"],"info":{"message":"The new rule flags more situations where object literal syntax can be used, and it does not report a problem when the `Object` constructor is invoked with an argument.","url":"https://eslint.org/blog/2023/09/eslint-v8.50.0-released/","deprecatedSince":"8.50.0","availableUntil":null,"replacedBy":[{"rule":{"name":"no-object-constructor","url":"https://eslint.org/docs/rules/no-object-constructor"}}]}}]},{"filePath":"/Users/wolf/Desktop/Plubot/plubot-frontend/src/contexts/FlowEditorContext.jsx","messages":[{"ruleId":"no-unused-vars","severity":1,"message":"'useNodeCreator' is defined but never used. Allowed unused vars must match /^[A-Z_]|^_/u.","line":6,"column":8,"nodeType":"Identifier","messageId":"unusedVar","endLine":6,"endColumn":22,"suggestions":[{"messageId":"removeVar","data":{"varName":"useNodeCreator"},"fix":{"range":[249,269],"text":""},"desc":"Remove unused variable 'useNodeCreator'."}]},{"ruleId":"sonarjs/unused-import","severity":2,"message":"Remove this unused import of 'useNodeCreator'.","line":6,"column":8,"nodeType":"Identifier","messageId":"removeUnusedImport","endLine":6,"endColumn":22,"suggestions":[{"messageId":"suggestRemoveWholeStatement","fix":{"range":[241,294],"text":""},"desc":"Remove this import statement"}]},{"ruleId":"no-unused-vars","severity":1,"message":"'useVirtualization' is defined but never used. Allowed unused vars must match /^[A-Z_]|^_/u.","line":10,"column":8,"nodeType":"Identifier","messageId":"unusedVar","endLine":10,"endColumn":25,"suggestions":[{"messageId":"removeVar","data":{"varName":"useVirtualization"},"fix":{"range":[363,386],"text":""},"desc":"Remove unused variable 'useVirtualization'."}]},{"ruleId":"sonarjs/unus