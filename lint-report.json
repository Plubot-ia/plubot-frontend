umn":47},{"ruleId":"react/prop-types","severity":1,"message":"'plubot.powers' is missing in props validation","line":81,"column":23,"nodeType":"Identifier","messageId":"missingPropType","endLine":81,"endColumn":29},{"ruleId":"react/prop-types","severity":1,"message":"'plubot.powers.map' is missing in props validation","line":81,"column":30,"nodeType":"Identifier","messageId":"missingPropType","endLine":81,"endColumn":33},{"ruleId":"react/prop-types","severity":1,"message":"'plubot.flows' is missing in props validation","line":99,"column":17,"nodeType":"Identifier","messageId":"missingPropType","endLine":99,"endColumn":22},{"ruleId":"react/prop-types","severity":1,"message":"'plubot.flows' is missing in props validation","line":99,"column":33,"nodeType":"Identifier","messageId":"missingPropType","endLine":99,"endColumn":38},{"ruleId":"react/prop-types","severity":1,"message":"'plubot.flows.length' is missing in props validation","line":99,"column":39,"nodeType":"Identifier","messageId":"missingPropType","endLine":99,"endColumn":45},{"ruleId":"react/prop-types","severity":1,"message":"'plubot.flows' is missing in props validation","line":103,"column":23,"nodeType":"Identifier","messageId":"missingPropType","endLine":103,"endColumn":28},{"ruleId":"react/prop-types","severity":1,"message":"'plubot.flows.map' is missing in props validation","line":103,"column":29,"nodeType":"Identifier","messageId":"missingPropType","endLine":103,"endColumn":32},{"ruleId":"react/prop-types","severity":1,"message":"'plubot.edges' is missing in props validation","line":137,"column":17,"nodeType":"Identifier","messageId":"missingPropType","endLine":137,"endColumn":22},{"ruleId":"react/prop-types","severity":1,"message":"'plubot.edges' is missing in props validation","line":137,"column":33,"nodeType":"Identifier","messageId":"missingPropType","endLine":137,"endColumn":38},{"ruleId":"react/prop-types","severity":1,"message":"'plubot.edges.length' is missing in props validation","line":137,"column":39,"nodeType":"Identifier","messageId":"missingPropType","endLine":137,"endColumn":45},{"ruleId":"react/prop-types","severity":1,"message":"'plubot.edges' is missing in props validation","line":141,"column":23,"nodeType":"Identifier","messageId":"missingPropType","endLine":141,"endColumn":28},{"ruleId":"react/prop-types","severity":1,"message":"'plubot.edges.map' is missing in props validation","line":141,"column":29,"nodeType":"Identifier","messageId":"missingPropType","endLine":141,"endColumn":32},{"ruleId":"react/prop-types","severity":1,"message":"'plubot.powers' is missing in props validation","line":160,"column":59,"nodeType":"Identifier","messageId":"missingPropType","endLine":160,"endColumn":65}],"suppressedMessages":[],"errorCount":7,"fatalErrorCount":0,"warningCount":33,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React from 'react';\n\nimport { powers } from '@/data/powers';\n\n/**\n * Componente que muestra los detalles de un plubot en un modal\n * @param {Object} props - Propiedades del componente\n * @param {Object} props.plubot - Datos del plubot a mostrar\n * @param {Function} props.setModalPlubot - Función para cerrar el modal\n * @param {Function} props.navigate - Función de navegación\n */\nconst PlubotDetailsModal = ({ plubot, setModalPlubot, navigate }) => {\n  const getPowerDetails = (powerId) => {\n    const power = powers.find((p) => p.id === powerId);\n    return power\n      ? { title: power.title, icon: power.icon, description: power.description }\n      : { title: powerId, icon: '⚡', description: 'Desconocido' };\n  };\n\n  const getAvailablePower = (currentPowers) => {\n    const availablePowers = powers.filter(\n      (p) => !currentPowers?.includes(p.id),\n    );\n    return availablePowers.length > 0 ? availablePowers[0] : null;\n  };\n\n  return (\n    <div\n      className='modal-overlay modal-overlay-immediate'\n      onClick={() => setModalPlubot(null)}\n      onKeyDown={(e) => e.key === 'Enter' && setModalPlubot(null)}\n      role='button'\n      tabIndex='0'\n      aria-label='Cerrar modal'\n      onKeyUp={(e) => e.key === 'Escape' && setModalPlubot(null)}\n    >\n      <div\n        className='modal-content animated animate-in modal-content-styles'\n        // Nota: No se asignan eventos aquí para cumplir con accesibilidad.\n        // La propagación se maneja de otra forma si es necesario.\n        role='dialog'\n        aria-labelledby='plubot-modal-title'\n      >\n        <button\n          className='modal-close glow-effect'\n          onClick={() => setModalPlubot(null)}\n        >\n          ✖\n        </button>\n        <div className='plubot-icon-container plubot-icon-container-styles'>\n          <div className='plubot-icon plubot-icon-styles'>\n            {plubot.powers && plubot.powers.length > 0\n              ? getPowerDetails(plubot.powers[0]).icon\n              : '🤖'}\n          </div>\n        </div>\n        <h3\n          id='plubot-modal-title'\n          className='modal-title text-glow modal-title-styles'\n        >\n          {plubot.name || 'Plubot'}\n        </h3>\n        <p className='modal-paragraph-id'>\n          <strong>ID:</strong> {plubot.id}\n        </p>\n        <p className='modal-paragraph-integrations'>\n          Tu Plubot actualmente está conectado a{' '}\n          <span className='modal-integrations-highlight'>\n            {plubot.powers && plubot.powers.length > 0\n              ? plubot.powers\n                  .map((powerId) => getPowerDetails(powerId).title)\n                  .join(', ')\n              : 'ninguna integración'}\n          </span>\n          .\n        </p>\n        {plubot.powers && plubot.powers.length > 0 && (\n          <div className='modal-powers-container'>\n            <h4 className='modal-powers-title'>Poderes Activos</h4>\n            <ul className='modal-powers-list'>\n              {plubot.powers.map((powerId) => (\n                <li key={powerId} className='modal-power-item'>\n                  <span className='modal-power-icon'>\n                    {getPowerDetails(powerId).icon}\n                  </span>\n                  <div>\n                    <div className='modal-power-name'>\n                      {getPowerDetails(powerId).title}\n                    </div>\n                    <div className='modal-power-description'>\n                      {getPowerDetails(powerId).description}\n                    </div>\n                  </div>\n                </li>\n              ))}\n            </ul>\n          </div>\n        )}\n        {plubot.flows && plubot.flows.length > 0 ? (\n          <div className='modal-flows-container'>\n            <h4 className='modal-flows-title'>Flujos Configurados</h4>\n            <ul className='modal-flows-list'>\n              {plubot.flows.map((flow) => (\n                <li\n                  key={\n                    flow.id ||\n                    `flow-${flow.intent}-${flow.user_message || 'default'}`\n                  }\n                  className='modal-flow-item'\n                >\n                  <div className='modal-flow-name'>\n                    Flujo {flow.position || 'N/A'} ({flow.intent})\n                  </div>\n                  <div className='modal-flow-description'>\n                    <strong>Mensaje del usuario:</strong>{' '}\n                    {flow.user_message || 'N/A'}\n                    <br />\n                    <strong>Respuesta del bot:</strong>{' '}\n                    {flow.bot_response || 'N/A'}\n                    <br />\n                    <strong>Condición:</strong> {flow.condition || 'Ninguna'}\n                    <br />\n                    <strong>Posición:</strong> {flow.position || 'N/A'}\n                  </div>\n                </li>\n              ))}\n            </ul>\n          </div>\n        ) : (\n          <div className='modal-empty-flows'>\n            <p>\n              No hay flujos configurados para este Plubot. Configúralos en el\n              editor de flujos.\n            </p>\n          </div>\n        )}\n        {plubot.edges && plubot.edges.length > 0 ? (\n          <div className='modal-edges-container'>\n            <h4 className='modal-edges-title'>Conexiones</h4>\n            <ul className='modal-edges-list'>\n              {plubot.edges.map((edge) => (\n                <li\n                  key={`edge-${edge.source}-${edge.target}`}\n                  className='modal-edge-item'\n                >\n                  <div className='modal-edge-description'>\n                    <strong>Conexión:</strong> Desde nodo {edge.source} hacia\n                    nodo {edge.target}\n                  </div>\n                </li>\n              ))}\n            </ul>\n          </div>\n        ) : (\n          <div className='modal-empty-edges'>\n            <p>No hay conexiones definidas para este Plubot.</p>\n          </div>\n        )}\n        {(() => {\n          const availablePower = getAvailablePower(plubot.powers || []);\n          return availablePower ? (\n            <div className='modal-available-power-container'>\n              <div className='modal-available-power-bg' />\n              <p className='modal-available-power-text'>\n                ¡Agrega{' '}\n                <strong className='modal-available-power-highlight'>\n                  {availablePower.title}\n                </strong>{' '}\n                para desbloquear la capacidad de{' '}\n                {availablePower.description.toLowerCase()}!\n              </p>\n            </div>\n          ) : (\n            <div className='modal-all-powers-container'>\n              <p>\n                Tu Plubot ya tiene todas las integraciones disponibles. ¡Sigue\n                creando!\n              </p>\n            </div>\n          );\n        })()}\n        <button\n          className='cyber-button glow-effect modal-modify-plubot-button'\n          onClick={() => navigate('/factory')}\n        >\n          MODIFICAR PLUBOT\n        </button>\n      </div>\n    </div>\n  );\n};\n\nexport default PlubotDetailsModal;\n","usedDeprecatedRules":[{"ruleId":"sonarjs/updated-loop-counter","replacedBy":[]},{"ruleId":"no-new-object","replacedBy":["no-object-constructor"],"info":{"message":"The new rule flags more situations where object literal syntax can be used, and it does not report a problem when the `Object` constructor is invoked with an argument.","url":"https://eslint.org/blog/2023/09/eslint-v8.50.0-released/","deprecatedSince":"8.50.0","availableUntil":null,"replacedBy":[{"rule":{"name":"no-object-constructor","url":"https://eslint.org/docs/rules/no-object-constructor"}}]}}]},{"filePath":"/Users/wolf/Desktop/Plubot/plubot-frontend/src/pages/profile/components/PlubotSection.jsx","messages":[{"ruleId":"complexity","severity":1,"message":"Arrow function has a complexity of 18. Maximum allowed is 15.","line":10,"column":3,"nodeType":"ArrowFunctionExpression","messageId":"complex","endLine":150,"endColumn":4},{"ruleId":"react/prop-types","severity":1,"message":"'plubot' is missing in props validation","line":11,"column":5,"nodeType":"Property","messageId":"missingPropType","endLine":11,"endColumn":11},{"ruleId":"react/prop-types","severity":1,"message":"'index' is missing in props validation","line":12,"column":5,"nodeType":"Property","messageId":"missingPropType","endLine":12,"endColumn":10},{"ruleId":"react/prop-types","severity":1,"message":"'animateBadges' is missing in props validation","line":13,"column":5,"nodeType":"Property","messageId":"missingPropType","endLine":13,"endColumn":18},{"ruleId":"react/prop-types","severity":1,"message":"'getPowerDetails' is missing in props validation","line":14,"column":5,"nodeType":"Property","messageId":"missingPropType","endLine":14,"endColumn":20},{"ruleId":"react/prop-types","severity":1,"message":"'handleViewDetails' is missing in props validation","line":15,"column":5,"nodeType":"Property","messageId":"missingPropType","endLine":15,"endColumn":22},{"ruleId":"react/prop-types","severity":1,"message":"'handleForceRemovePlubot' is missing in props validation","line":16,"column":5,"nodeType":"Property","messageId":"missingPropType","endLine":16,"endColumn":28},{"ruleId":"react/prop-types","severity":1,"message":"'requestDeletePlubot' is missing in props validation","line":17,"column":5,"nodeType":"Property","messageId":"missingPropType","endLine":17,"endColumn":24},{"ruleId":"react/prop-types","severity":1,"message":"'setEditModalPlubot' is missing in props validation","line":18,"column":5,"nodeType":"Property","messageId":"missingPropType","endLine":18,"endColumn":23},{"ruleId":"react/prop-types","severity":1,"message":"'deletingPlubotIds' is missing in props validation","line":19,"column":5,"nodeType":"Property","messageId":"missingPropType","endLine":19,"endColumn":22},{"ruleId":"react/prop-types","severity":1,"message":"'unremovablePlubots' is missing in props validation","line":20,"column":5,"nodeType":"Property","messageId":"missingPropType","endLine":20,"endColumn":23},{"ruleId":"react/prop-types","severity":1,"message":"'showNotification' is missing in props validation","line":21,"column":5,"nodeType":"Property","messageId":"missingPropType","endLine":21,"endColumn":21},{"ruleId":"react/prop-types","severity":1,"message":"'plubot.powers' is missing in props validation","line":23,"column":47,"nodeType":"Identifier","messageId":"missingPropType","endLine":23,"endColumn":53},{"ruleId":"react/prop-types","severity":1,"message":"'plubot.powers' is missing in props validation","line":24,"column":16,"nodeType":"Identifier","messageId":"missingPropType","endLine":24,"endColumn":22},{"ruleId":"react/prop-types","severity":1,"message":"'plubot.powers.filter' is missing in props validation","line":24,"column":23,"nodeType":"Identifier","messageId":"missingPropType","endLine":24,"endColumn":29},{"ruleId":"react/prop-types","severity":1,"message":"'deletingPlubotIds.includes' is missing in props validation","line":33,"column":42,"nodeType":"Identifier","messageId":"missingPropType","endLine":33,"endColumn":50},{"ruleId":"react/prop-types","severity":1,"message":"'plubot.id' is missing in props validation","line":33,"column":58,"nodeType":"Identifier","messageId":"missingPropType","endLine":33,"endColumn":60},{"ruleId":"react/prop-types","severity":1,"message":"'unremovablePlubots.includes' is missing in props validation","line":34,"column":46,"nodeType":"Identifier","messageId":"missingPropType","endLine":34,"endColumn":54},{"ruleId":"react/prop-types","severity":1,"message":"'plubot.id' is missing in props validation","line":34,"column":62,"nodeType":"Identifier","messageId":"missingPropType","endLine":34,"endColumn":64},{"ruleId":"react/prop-types","severity":1,"message":"'plubot.color' is missing in props validation","line":41,"column":18,"nodeType":"Identifier","messageId":"missingPropType","endLine":41,"endColumn":23},{"ruleId":"react/prop-types","severity":1,"message":"'plubot.color' is missing in props validation","line":46,"column":30,"nodeType":"Identifier","messageId":"missingPropType","endLine":46,"endColumn":35},{"ruleId":"react/prop-types","severity":1,"message":"'plubot.color' is missing in props validation","line":47,"column":49,"nodeType":"Identifier","messageId":"missingPropType","endLine":47,"endColumn":54},{"ruleId":"react/prop-types","severity":1,"message":"'plubot.color' is missing in props validation","line":49,"column":31,"nodeType":"Identifier","messageId":"missingPropType","endLine":49,"endColumn":36},{"ruleId":"react/prop-types","severity":1,"message":"'plubot.name' is missing in props validation","line":83,"column":19,"nodeType":"Identifier","messageId":"missingPropType","endLine":83,"endColumn":23},{"ruleId":"react/prop-types","severity":1,"message":"'plubot.tone' is missing in props validation","line":96,"column":33,"nodeType":"Identifier","messageId":"missingPropType","endLine":96,"endColumn":37},{"ruleId":"react/prop-types","severity":1,"message":"'plubot.id' is missing in props validation","line":107,"column":38,"nodeType":"Identifier","messageId":"missingPropType","endLine":107,"endColumn":40},{"ruleId":"react/prop-types","severity":1,"message":"'plubot.id' is missing in props validation","line":130,"column":61,"nodeType":"Identifier","messageId":"missingPropType","endLine":130,"endColumn":63},{"ruleId":"sonarjs/no-commented-code","severity":2,"message":"Remove this commented out code.","line":153,"column":1,"nodeType":null,"messageId":"commentedCode","endLine":153,"endColumn":101,"suggestions":[{"messageId":"commentedCodeFix","fix":{"range":[4622,4722],"text":""},"desc":"Remove this commented out code"}]},{"ruleId":"max-lines-per-function","severity":1,"message":"Arrow function has too many lines (274). Maximum allowed is 150.","line":156,"column":3,"nodeType":"ArrowFunctionExpression","messageId":"exceed","endLine":455,"endColumn":4},{"ruleId":"react/prop-types","severity":1,"message":"'animateBadges' is missing in props validation","line":157,"column":5,"nodeType":"Property","messageId":"missingPropType","endLine":157,"endColumn":18},{"ruleId":"react/prop-types","severity":1,"message":"'setModalPlubot' is missing in props validation","line":158,"column":5,"nodeType":"Property","messageId":"missingPropType","endLine":158,"endColumn":19},{"ruleId":"react/prop-types","severity":1,"message":"'setEditModalPlubot' is missing in props validation","line":159,"column":5,"nodeType":"Property","messageId":"missingPropType","endLine":159,"endColumn":23},{"ruleId":"react/prop-types","severity":1,"message":"'showNotification' is missing in props validation","line":160,"column":5,"nodeType":"Property","messageId":"missingPropType","endLine":160,"endColumn":21},{"ruleId":"react/prop-types","severity":1,"message":"'navigate' is missing in props validation","line":161,"column":5,"nodeType":"Property","messageId":"missingPropType","endLine":161,"endColumn":13},{"ruleId":"unicorn/no-null","severity":2,"message":"Use `undefined` instead of `null`.","line":210,"column":15,"nodeType":"Literal","messageId":"error","endLine":210,"endColumn":19,"suggestions":[{"messageId":"replace","fix":{"range":[6540,6544],"text":"undefined"},"data":{},"desc":"Replace `null` with `undefined`."}]},{"ruleId":"unicorn/no-null","severity":2,"message":"Use `undefined` instead of `null`.","line":296,"column":54,"nodeType":"Literal","messageId":"error","endLine":296,"endColumn":58,"suggestions":[{"messageId":"replace","fix":{"range":[9477,9481],"text":"undefined"},"data":{},"desc":"Replace `null` with `undefined`."}]}],"suppressedMessages":[],"errorCount":3,"fatalErrorCount":0,"warningCount":33,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React, { memo, useCallback, useState, useEffect } from 'react';\n\nimport { powers } from '@/data/powers'; // Corregido: import 'powers' from '@data/powers'\nimport axiosInstance from '@/utils/axios-config.js'; // Corregido para usar alias @\n\nimport logger from '../../../services/loggerService'; // <--- AÑADIR IMPORTACIÓN\nimport useAuthStore from '../../../stores/use-auth-store';\n\nconst PlubotCard = memo(\n  ({\n    plubot,\n    index,\n    animateBadges,\n    getPowerDetails,\n    handleViewDetails,\n    handleForceRemovePlubot,\n    requestDeletePlubot,\n    setEditModalPlubot,\n    deletingPlubotIds,\n    unremovablePlubots,\n    showNotification,\n  }) => {\n    const plubotPowers = Array.isArray(plubot.powers)\n      ? plubot.powers.filter(Boolean)\n      : [];\n    const plubotPowerTitles =\n      plubotPowers\n        .map((powerId) => getPowerDetails(powerId).title)\n        .join(', ') || 'Ninguno';\n    const plubotIcon =\n      plubotPowers.length > 0 ? getPowerDetails(plubotPowers[0]).icon : '🤖';\n\n    const isDeleting = deletingPlubotIds.includes(plubot.id);\n    const isUnremovable = unremovablePlubots.includes(plubot.id);\n\n    return (\n      <div\n        className={`\n        plubot-card \n        ${animateBadges ? 'animate-in' : ''} \n        ${plubot.color ? '' : 'plubot-card-fallback'} \n        ${isDeleting ? 'deleting' : ''} \n        ${isUnremovable ? 'unremovable' : ''}\n      `}\n        style={{\n          background: plubot.color\n            ? `linear-gradient(135deg, ${plubot.color}40, rgba(0, 40, 80, 0.8))`\n            : undefined,\n          borderColor: plubot.color || undefined,\n          animationDelay: `${index * 150}ms`,\n          opacity: isDeleting ? 0.6 : 1,\n          position: 'relative',\n        }}\n      >\n        {isDeleting && (\n          <div\n            className='deleting-overlay'\n            style={{\n              position: 'absolute',\n              top: 0,\n              left: 0,\n              right: 0,\n              bottom: 0,\n              display: 'flex',\n              alignItems: 'center',\n              justifyContent: 'center',\n              backgroundColor: 'rgba(0,0,0,0.7)',\n              zIndex: 10,\n              borderRadius: 'inherit',\n            }}\n          >\n            <span style={{ color: '#00e0ff', fontWeight: 'bold' }}>\n              Eliminando...\n            </span>\n          </div>\n        )}\n\n        <div className='plubot-icon-container'>\n          <div className='plubot-icon'>{plubotIcon}</div>\n        </div>\n\n        <h4 className='plubot-name'>\n          {plubot.name || 'Plubot'}\n          {isUnremovable && (\n            <span\n              title='Este Plubot no existe en el servidor pero aparece en la interfaz'\n              style={{ color: '#ff9800' }}\n            >\n              {' '}\n              (Fantasma)\n            </span>\n          )}\n        </h4>\n\n        <div className='plubot-detail'>\n          Personalidad: {plubot.tone || 'N/A'}\n        </div>\n        <div className='plubot-powers'>\n          <div className='plubot-detail'>\n            <strong>Poderes:</strong> {plubotPowerTitles}\n          </div>\n        </div>\n        <div className='plubot-actions'>\n          <button\n            className='plubot-button icon-button'\n            onClick={() => {\n              if (!plubot || !plubot.id) {\n                showNotification('Error: Plubot no válido.', 'error');\n                return;\n              }\n              setEditModalPlubot(plubot);\n            }}\n            title='Editar Plubot'\n            disabled={isDeleting || isUnremovable}\n          >\n            ⚙️\n          </button>\n          <button\n            className='plubot-button icon-button view-button'\n            onClick={() => handleViewDetails(plubot)}\n            title='Ver detalles'\n            disabled={isDeleting || isUnremovable}\n          >\n            👁️\n          </button>\n\n          {isUnremovable ? (\n            <button\n              className='plubot-button icon-button force-delete-button'\n              onClick={() => handleForceRemovePlubot(plubot.id)}\n              title='Eliminar de la interfaz'\n              style={{ background: '#ff5722' }}\n              disabled={isDeleting}\n            >\n              🗑️🚫\n            </button>\n          ) : (\n            <button\n              className='plubot-button icon-button delete-button'\n              onClick={() => requestDeletePlubot(plubot)}\n              title='Eliminar'\n              disabled={isDeleting}\n            >\n              🗑️\n            </button>\n          )}\n        </div>\n      </div>\n    );\n  },\n);\nPlubotCard.displayName = 'PlubotCard';\n// import './PlubotSection.css'; // Eliminada porque el archivo no existe y no parece ser necesario.\n\nconst PlubotSection = memo(\n  ({\n    animateBadges,\n    setModalPlubot,\n    setEditModalPlubot,\n    showNotification,\n    navigate,\n  }) => {\n    const { user, setUser, fetchUserProfile } = useAuthStore();\n\n    const getPowerDetails = useCallback((powerId) => {\n      const power = powers.find((p) => p.id === powerId);\n      return power\n        ? {\n            title: power.title,\n            icon: power.icon,\n            description: power.description,\n          }\n        : { title: powerId, icon: '⚡', description: 'Desconocido' };\n    }, []);\n\n    const handleViewDetails = useCallback(\n      async (plubot) => {\n        if (!plubot || !plubot.id) {\n          showNotification(\n            'Error: Datos del Plubot inválidos para ver detalles.',\n            'error',\n          );\n          return;\n        }\n        try {\n          const response = await axiosInstance.get(`/plubots/${plubot.id}`);\n          if (response.data.status === 'success' && response.data.plubot) {\n            setModalPlubot(response.data.plubot);\n          } else {\n            const errorMessage =\n              response.data.message ||\n              'Error al cargar los detalles del Plubot desde el backend.';\n            showNotification(errorMessage, 'error');\n          }\n        } catch (error) {\n          const errorMessage =\n            error.response?.data?.message ||\n            error.message ||\n            'Error de red o desconocido al cargar detalles.';\n          showNotification(errorMessage, 'error');\n        }\n      },\n      [setModalPlubot, showNotification],\n    );\n\n    const [deletingPlubotIds, setDeletingPlubotIds] = useState([]);\n    const [unremovablePlubots, setUnremovablePlubots] = useState([]);\n    const [deleteConfirmState, setDeleteConfirmState] = useState({\n      isOpen: false,\n      plubot: null,\n    });\n\n    const handleDeletePlubot = useCallback(\n      async (plubotId) => {\n        if (!plubotId || deletingPlubotIds.includes(plubotId)) {\n          return;\n        }\n\n        setDeletingPlubotIds((previous) => [...previous, plubotId]);\n\n        try {\n          const response = await axiosInstance.delete(\n            `/auth/profile/plubots/${plubotId}`,\n          );\n\n          if (response.status === 200) {\n            showNotification('Plubot eliminado exitosamente.', 'success');\n            await fetchUserProfile(true);\n          } else {\n            const errorData = response.data;\n            showNotification(\n              `Error al eliminar: ${errorData.message || 'Error desconocido'}`,\n              'error',\n            );\n          }\n        } catch (error) {\n          logger.error('Error al eliminar Plubot:', error);\n          const apiError = error.response?.data || {};\n          if (apiError.response?.status === 404) {\n            setUnremovablePlubots((previous) => {\n              if (previous.includes(plubotId)) {\n                return previous;\n              }\n              return [...previous, plubotId];\n            });\n            showNotification(\n              'Plubot no encontrado en el servidor. Puedes forzar su eliminación de esta lista si persiste.',\n              'warning',\n            );\n          } else if (\n            apiError.response?.status === 401 ||\n            apiError.message?.includes('sesión')\n          ) {\n            navigate('/login');\n            showNotification(\n              'Tu sesión ha expirado. Por favor, inicia sesión de nuevo.',\n              'error',\n            );\n          } else {\n            const errorMessage =\n              apiError.message || 'Error de red o desconocido';\n            showNotification(\n              `Error al eliminar Plubot: ${errorMessage.slice(0, 50)}...`,\n              'error',\n            );\n          }\n        } finally {\n          setDeletingPlubotIds((previous) =>\n            previous.filter((id) => id !== plubotId),\n          );\n        }\n      },\n      [showNotification, navigate, deletingPlubotIds, fetchUserProfile],\n    );\n\n    const handleForceRemovePlubot = useCallback(\n      (plubotId) => {\n        if (user && Array.isArray(user.plubots)) {\n          const updatedPlubots = user.plubots.filter((p) => p.id !== plubotId);\n          const updatedUser = { ...user, plubots: updatedPlubots };\n          setUser(updatedUser);\n          showNotification('Plubot eliminado de la vista local', 'success');\n          setUnremovablePlubots((previous) =>\n            previous.filter((id) => id !== plubotId),\n          );\n        }\n      },\n      [user, setUser, showNotification],\n    );\n\n    const requestDeletePlubot = useCallback((plubot) => {\n      setDeleteConfirmState({ isOpen: true, plubot });\n    }, []);\n\n    const cancelDeletePlubot = () => {\n      setDeleteConfirmState({ isOpen: false, plubot: null });\n    };\n\n    const confirmDeletePlubot = () => {\n      if (deleteConfirmState.plubot) {\n        handleDeletePlubot(deleteConfirmState.plubot.id);\n      }\n      cancelDeletePlubot();\n    };\n\n    // Styles for Delete Confirmation Modal\n    const modalOverlayStyle = {\n      position: 'fixed',\n      top: 0,\n      left: 0,\n      right: 0,\n      bottom: 0,\n      backgroundColor: 'rgba(0,0,0,0.7)',\n      display: 'flex',\n      alignItems: 'center',\n      justifyContent: 'center',\n      zIndex: 10_000,\n    };\n\n    const modalContentStyle = {\n      backgroundColor: '#1a2035',\n      color: '#00e0ff',\n      padding: '30px',\n      borderRadius: '10px',\n      border: '1px solid #ff00ff',\n      textAlign: 'center',\n      boxShadow: '0 0 20px rgba(255,0,255,0.5)',\n      maxWidth: '400px',\n    };\n\n    const modalTitleStyle = {\n      marginTop: 0,\n      color: '#ff00ff',\n      fontSize: '1.5em',\n    };\n    const modalStrongStyle = { color: '#ff00ff' };\n    const modalTextStyle = { fontSize: '1.1em' };\n    const modalButtonContainerStyle = { marginTop: '25px' };\n\n    const modalButtonStyle = {\n      cursor: 'pointer',\n      fontWeight: 'bold',\n      textTransform: 'uppercase',\n      letterSpacing: '1px',\n      padding: '12px 25px',\n      borderRadius: '5px',\n    };\n\n    const confirmButtonStyle = {\n      ...modalButtonStyle,\n      backgroundColor: '#ff00ff',\n      color: 'white',\n      border: '1px solid #00e0ff',\n      marginRight: '15px',\n    };\n\n    const cancelButtonStyle = {\n      ...modalButtonStyle,\n      backgroundColor: 'transparent',\n      color: '#00e0ff',\n      border: '1px solid #00e0ff',\n    };\n\n    // Efecto para garantizar que el perfil se renderice correctamente\n    useEffect(() => {\n      if (user && Array.isArray(user.plubots)) {\n        // Registrar en consola para depuración\n      }\n    }, [user]);\n\n    return (\n      <div className='profile-section plubots-section'>\n        <h3 className='plubots-section-title'>PLUBOTS CREADOS</h3>\n        <div className='plubots-background' />\n\n        {deleteConfirmState.isOpen && deleteConfirmState.plubot && (\n          <div style={modalOverlayStyle}>\n            <div style={modalContentStyle}>\n              <h3 style={modalTitleStyle}>Confirmar Desintegración Quántica</h3>\n              <p style={modalTextStyle}>\n                Estás a punto de enviar al Plubot{' '}\n                <strong style={modalStrongStyle}>\n                  {deleteConfirmState.plubot.name}\n                </strong>{' '}\n                al vacío.\n              </p>\n              <p>\n                Esta acción es irreversible y su rastro de Quanta se perderá\n                para siempre.\n              </p>\n              <div style={modalButtonContainerStyle}>\n                <button\n                  onClick={confirmDeletePlubot}\n                  style={confirmButtonStyle}\n                >\n                  Confirmar Desintegración\n                </button>\n                <button onClick={cancelDeletePlubot} style={cancelButtonStyle}>\n                  Cancelar\n                </button>\n              </div>\n            </div>\n          </div>\n        )}\n\n        {(() => {\n          // IIFE para lógica de renderizado condicional más compleja\n          if (!user || user.plubots === undefined) {\n            // user.plubots puede ser null si así lo devuelve el backend inicialmente\n            return (\n              <p className='no-plubots-message'>\n                Cargando Plubots o datos no disponibles...\n              </p>\n            );\n          }\n          if (!Array.isArray(user.plubots)) {\n            return (\n              <p className='no-plubots-message'>\n                Error: Formato de datos de Plubots incorrecto. Por favor,\n                recarga la página o contacta a soporte.\n              </p>\n            );\n          }\n          if (user.plubots.length === 0) {\n            return (\n              <p className='no-plubots-message'>\n                Aún no has creado ningún Plubot. ¡Empieza tu aventura en el\n                Pluniverse!\n              </p>\n            );\n          }\n          return (\n            <div className='plubots-grid'>\n              {user.plubots.map((plubot, index) => (\n                <PlubotCard\n                  key={plubot.id}\n                  plubot={plubot}\n                  index={index}\n                  animateBadges={animateBadges}\n                  getPowerDetails={getPowerDetails}\n                  handleViewDetails={handleViewDetails}\n                  handleForceRemovePlubot={handleForceRemovePlubot}\n                  requestDeletePlubot={requestDeletePlubot}\n                  setEditModalPlubot={setEditModalPlubot}\n                  deletingPlubotIds={deletingPlubotIds}\n                  unremovablePlubots={unremovablePlubots}\n                  showNotification={showNotification}\n                />\n              ))}\n            </div>\n          );\n        })()}\n      </div>\n    );\n  },\n);\n\nPlubotSection.displayName = 'PlubotSection';\n\nexport default PlubotSection;\n","usedDeprecatedRules":[{"ruleId":"sonarjs/updated-loop-counter","replacedBy":[]},{"ruleId":"no-new-object","replacedBy":["no-object-constructor"],"info":{"message":"The new rule flags more situations where object literal syntax can be used, and it does not report a problem when the `