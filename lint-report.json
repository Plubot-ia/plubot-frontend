","endLine":57,"endColumn":24},{"ruleId":"no-undef","severity":2,"message":"'reflowTimeout' is not defined.","line":57,"column":39,"nodeType":"Identifier","messageId":"undef","endLine":57,"endColumn":52},{"ruleId":"no-shadow","severity":1,"message":"'canvas' is already declared in the upper scope on line 51 column 11.","line":67,"column":13,"nodeType":"Identifier","messageId":"noShadow","endLine":67,"endColumn":19},{"ruleId":"no-shadow","severity":1,"message":"'staticCanvas' is already declared in the upper scope on line 52 column 11.","line":68,"column":13,"nodeType":"Identifier","messageId":"noShadow","endLine":68,"endColumn":25},{"ruleId":"no-use-before-define","severity":2,"message":"'drawStaticElements' was used before it was defined.","line":89,"column":7,"nodeType":"Identifier","messageId":"usedBeforeDefined","endLine":89,"endColumn":25},{"ruleId":"no-shadow","severity":1,"message":"'width' is already declared in the upper scope on line 28 column 11.","line":95,"column":15,"nodeType":"Identifier","messageId":"noShadow","endLine":95,"endColumn":20},{"ruleId":"no-shadow","severity":1,"message":"'height' is already declared in the upper scope on line 28 column 18.","line":96,"column":15,"nodeType":"Identifier","messageId":"noShadow","endLine":96,"endColumn":21},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":142,"column":7,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":142,"endColumn":17},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":143,"column":9,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":143,"endColumn":15},{"ruleId":"sonarjs/pseudo-random","severity":2,"message":"Make sure that using this pseudorandom number generator is safe here.","line":143,"column":19,"nodeType":"CallExpression","messageId":"safeGenerator","endLine":143,"endColumn":32},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":144,"column":9,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":144,"endColumn":15},{"ruleId":"sonarjs/pseudo-random","severity":2,"message":"Make sure that using this pseudorandom number generator is safe here.","line":144,"column":19,"nodeType":"CallExpression","messageId":"safeGenerator","endLine":144,"endColumn":32},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":145,"column":9,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":145,"endColumn":18},{"ruleId":"sonarjs/pseudo-random","severity":2,"message":"Make sure that using this pseudorandom number generator is safe here.","line":145,"column":21,"nodeType":"CallExpression","messageId":"safeGenerator","endLine":145,"endColumn":34},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":146,"column":9,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":146,"endColumn":20},{"ruleId":"sonarjs/pseudo-random","severity":2,"message":"Make sure that using this pseudorandom number generator is safe here.","line":146,"column":23,"nodeType":"CallExpression","messageId":"safeGenerator","endLine":146,"endColumn":36},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":147,"column":9,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":147,"endColumn":20},{"ruleId":"sonarjs/pseudo-random","severity":2,"message":"Make sure that using this pseudorandom number generator is safe here.","line":147,"column":23,"nodeType":"CallExpression","messageId":"safeGenerator","endLine":147,"endColumn":36},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":148,"column":9,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":148,"endColumn":23},{"ruleId":"sonarjs/pseudo-random","severity":2,"message":"Make sure that using this pseudorandom number generator is safe here.","line":149,"column":11,"nodeType":"CallExpression","messageId":"safeGenerator","endLine":149,"endColumn":24},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":150,"column":9,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":150,"endColumn":19},{"ruleId":"sonarjs/pseudo-random","severity":2,"message":"Make sure that using this pseudorandom number generator is safe here.","line":150,"column":22,"nodeType":"CallExpression","messageId":"safeGenerator","endLine":150,"endColumn":35},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":153,"column":7,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":153,"endColumn":18},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":156,"column":22,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":156,"endColumn":28},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":157,"column":22,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":157,"endColumn":28},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":162,"column":13,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":162,"endColumn":24},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":163,"column":13,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":163,"endColumn":24},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":167,"column":9,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":167,"endColumn":15},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":167,"column":19,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":167,"endColumn":30},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":168,"column":9,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":168,"endColumn":15},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":168,"column":19,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":168,"endColumn":30},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":170,"column":13,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":170,"endColumn":19},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":170,"column":27,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":170,"endColumn":33},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":170,"column":63,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":170,"endColumn":74},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":171,"column":13,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":171,"endColumn":19},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":171,"column":27,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":171,"endColumn":33},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":172,"column":11,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":172,"endColumn":22},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":174,"column":9,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":174,"endColumn":20},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":175,"column":9,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":175,"endColumn":20},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":178,"column":7,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":178,"endColumn":16},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":180,"column":31,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":180,"endColumn":41},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":181,"column":32,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":181,"endColumn":46},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":183,"column":21,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":183,"endColumn":27},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":183,"column":29,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":183,"endColumn":35},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":183,"column":37,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":183,"endColumn":46},{"ruleId":"react/no-this-in-sfc","severity":2,"message":"Stateless functional components should not use `this`","line":187,"column":7,"nodeType":"MemberExpression","messageId":"noThisInSFC","endLine":187,"endColumn":17},{"ruleId":"security/detect-object-injection","severity":1,"message":"Generic Object Injection Sink","line":210,"column":22,"nodeType":"MemberExpression","endLine":210,"endColumn":38},{"ruleId":"security/detect-object-injection","severity":1,"message":"Generic Object Injection Sink","line":210,"column":43,"nodeType":"MemberExpression","endLine":210,"endColumn":60},{"ruleId":"security/detect-object-injection","severity":1,"message":"Generic Object Injection Sink","line":211,"column":22,"nodeType":"MemberExpression","endLine":211,"endColumn":38},{"ruleId":"security/detect-object-injection","severity":1,"message":"Generic Object Injection Sink","line":211,"column":43,"nodeType":"MemberExpression","endLine":211,"endColumn":60},{"ruleId":"security/detect-object-injection","severity":1,"message":"Generic Object Injection Sink","line":222,"column":19,"nodeType":"MemberExpression","endLine":222,"endColumn":35},{"ruleId":"security/detect-object-injection","severity":1,"message":"Generic Object Injection Sink","line":223,"column":19,"nodeType":"MemberExpression","endLine":223,"endColumn":35},{"ruleId":"security/detect-object-injection","severity":1,"message":"Generic Object Injection Sink","line":224,"column":19,"nodeType":"MemberExpression","endLine":224,"endColumn":36},{"ruleId":"security/detect-object-injection","severity":1,"message":"Generic Object Injection Sink","line":225,"column":19,"nodeType":"MemberExpression","endLine":225,"endColumn":36},{"ruleId":"unicorn/prevent-abbreviations","severity":1,"message":"Please rename the variable `e`. Suggested names are: `error`, `event_`. A more descriptive name will do too.","line":268,"column":30,"nodeType":"Identifier","messageId":"suggestion","endLine":268,"endColumn":31},{"ruleId":"unicorn/prevent-abbreviations","severity":1,"message":"Please rename the variable `e`. Suggested names are: `error`, `event_`. A more descriptive name will do too.","line":278,"column":30,"nodeType":"Identifier","messageId":"suggestion","endLine":278,"endColumn":31},{"ruleId":"unicorn/no-null","severity":2,"message":"Use `undefined` instead of `null`.","line":294,"column":38,"nodeType":"Literal","messageId":"error","endLine":294,"endColumn":42,"suggestions":[{"messageId":"replace","fix":{"range":[10098,10102],"text":"undefined"},"data":{},"desc":"Replace `null` with `undefined`."}]}],"suppressedMessages":[],"errorCount":49,"fatalErrorCount":0,"warningCount":18,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React, { useRef, useCallback, useEffect, useMemo } from 'react';\n\nimport useFlowStore from '@/stores/use-flow-store'; // Importar store de Zustand\n\nimport useWindowSize from '../../../../hooks/useWindowSize';\n\nimport './BackgroundScene.css';\n\nconst CONFIG = {\n  particleCount: 40, // Reducido para optimizar rendimiento\n  connectionDistance: 60, // Reducido para menos conexiones\n  mouseRadius: 100,\n  maxPixelRatio: 1, // Limitado a 1 para mejor rendimiento\n  blur: 0.6, // Aumentado para un efecto más difuso como en el espacio\n  colors: ['rgba(0, 224, 255,', 'rgba(255, 0, 255,', 'rgba(200, 100, 255,'], // Añadido tono púrpura\n  staticGradientOpacity: 0.018, // Reducido aún más para un fondo más oscuro y profundo\n  backgroundColor: 'rgba(1, 2, 6, 0.98)', // Negro azulado muy oscuro, similar al espacio profundo\n  starOpacity: 0.6, // Reducir brillo de estrellas/partículas\n};\n\n/**\n * Componente para renderizar un fondo personalizado en el editor de flujos\n * @param {Object} props - Propiedades del componente\n * @param {boolean} props.isUltraMode - Indica si el modo de ultra rendimiento está activado\n */\nconst BackgroundScene = () => {\n  const isUltraMode = useFlowStore((state) => state.isUltraMode); // Conexión directa al store\n  const { width, height } = useWindowSize();\n\n  // Referencias para los canvas y la animación\n  const canvasReference = useRef(null);\n  const staticCanvasReference = useRef(null);\n  const animationReference = useRef(null);\n  const mousePosition = useRef({ x: null, y: null });\n\n  // Efecto para el modo normal con partículas animadas\n  useEffect(() => {\n    // La animación solo se ejecuta si NO estamos en modo ultra.\n    if (isUltraMode) {\n      // Si hay una animación en curso, la cancelamos.\n      if (animationReference.current) {\n        cancelAnimationFrame(animationReference.current);\n        animationReference.current = null;\n      }\n      return;\n    }\n\n    // Usar la referencia global en lugar de una variable local\n    animationReference.current = null;\n\n    const canvas = canvasReference.current;\n    const staticCanvas = staticCanvasReference.current;\n    const context = canvas?.getContext('2d');\n    const staticContext = staticCanvas?.getContext('2d');\n\n    if (!canvas || !staticCanvas || !context || !staticContext) {\n      if (reflowTimeout) clearTimeout(reflowTimeout);\n      return;\n    }\n\n    const pixelRatio = Math.min(\n      window.devicePixelRatio || 1,\n      CONFIG.maxPixelRatio,\n    );\n\n    const updateCanvasDimensions = () => {\n      const canvas = canvasReference.current;\n      const staticCanvas = staticCanvasReference.current;\n      if (!canvas || !staticCanvas) return;\n\n      const w = width || 0;\n      const h = height || 0;\n\n      canvas.width = w * pixelRatio;\n      canvas.height = h * pixelRatio;\n      canvas.style.width = `${w}px`;\n      canvas.style.height = `${h}px`;\n\n      staticCanvas.width = w * pixelRatio;\n      staticCanvas.height = h * pixelRatio;\n      staticCanvas.style.width = `${w}px`;\n      staticCanvas.style.height = `${h}px`;\n\n      const context_ = canvas.getContext('2d');\n      context_.scale(pixelRatio, pixelRatio);\n      staticContext.setTransform(1, 0, 0, 1, 0, 0);\n      staticContext.scale(pixelRatio, pixelRatio);\n\n      drawStaticElements();\n    };\n\n    const drawStaticElements = () => {\n      staticContext.clearRect(0, 0, staticCanvas.width, staticCanvas.height);\n\n      const { width } = staticCanvas;\n      const { height } = staticCanvas;\n\n      // Aplicar un fondo más oscuro primero\n      staticContext.fillStyle = CONFIG.backgroundColor;\n      staticContext.fillRect(0, 0, width, height);\n\n      // Gradiente en la esquina superior izquierda (más reducido y sutil)\n      const gradient1 = staticContext.createRadialGradient(\n        width * 0.05,\n        height * 0.1,\n        0, // Posición más cercana a la esquina\n        width * 0.05,\n        height * 0.1,\n        width * 0.2, // Radio significativamente reducido\n      );\n      gradient1.addColorStop(\n        0,\n        `rgba(0, 224, 255, ${CONFIG.staticGradientOpacity * 0.4})`,\n      );\n      gradient1.addColorStop(1, 'transparent');\n\n      // Restaurar el gradiente magenta en la parte inferior derecha\n      const gradient2 = staticContext.createRadialGradient(\n        width * 0.9,\n        height * 0.8,\n        0,\n        width * 0.9,\n        height * 0.8,\n        width * 0.4,\n      );\n      gradient2.addColorStop(\n        0,\n        `rgba(255, 0, 255, ${CONFIG.staticGradientOpacity})`,\n      );\n      gradient2.addColorStop(1, 'transparent');\n\n      // Aplicar los gradientes con menor opacidad\n      staticContext.fillStyle = gradient1;\n      staticContext.fillRect(0, 0, width, height);\n      staticContext.fillStyle = gradient2;\n      staticContext.fillRect(0, 0, width, height);\n    };\n\n    updateCanvasDimensions();\n\n    function Particle() {\n      this.reset = () => {\n        this.x = (Math.random() * canvas.width) / pixelRatio;\n        this.y = (Math.random() * canvas.height) / pixelRatio;\n        this.size = Math.random() * 2 + 0.5;\n        this.speedX = Math.random() * 0.5 - 0.25;\n        this.speedY = Math.random() * 0.5 - 0.25;\n        this.colorBase =\n          Math.random() > 0.5 ? CONFIG.colors[0] : CONFIG.colors[1];\n        this.alpha = Math.random() * 0.4 + 0.1;\n      };\n\n      this.update = () => {\n        // Influencia del cursor\n        if (mousePosition.current.x && mousePosition.current.y) {\n          const dx = this.x - mousePosition.current.x;\n          const dy = this.y - mousePosition.current.y;\n          const distance = Math.hypot(dx, dy);\n\n          if (distance < CONFIG.mouseRadius) {\n            const force = (CONFIG.mouseRadius - distance) / CONFIG.mouseRadius;\n            this.speedX += dx * force * 0.02;\n            this.speedY += dy * force * 0.02;\n          }\n        }\n\n        this.x += this.speedX;\n        this.y += this.speedY;\n\n        if (this.x < 0 || this.x > canvas.width / pixelRatio) this.speedX *= -1;\n        if (this.y < 0 || this.y > canvas.height / pixelRatio)\n          this.speedY *= -1;\n\n        this.speedX *= 0.98;\n        this.speedY *= 0.98;\n      };\n\n      this.draw = () => {\n        // Aplicar la opacidad de estrella del CONFIG para lograr un efecto espacial más profundo\n        const adjustedAlpha = this.alpha * (CONFIG.starOpacity || 1);\n        context.fillStyle = `${this.colorBase}${adjustedAlpha})`;\n        context.beginPath();\n        context.arc(this.x, this.y, this.size, 0, Math.PI * 2);\n        context.fill();\n      };\n\n      this.reset();\n    }\n\n    const particles = Array.from(\n      { length: CONFIG.particleCount },\n      () => new Particle(),\n    );\n\n    const drawConnections = () => {\n      // Optimización: Usar un buffer de líneas y dibujarlas todas juntas\n      const lines = [];\n      context.lineWidth = 0.4;\n\n      // Limitar el número de conexiones para mejorar el rendimiento\n      const maxConnections = 100; // Límite de conexiones a dibujar\n      let connectionCount = 0;\n\n      for (let index = 0; index < particles.length; index++) {\n        // Optimización: Solo comprobar partículas cercanas\n        // Usar un paso más grande para saltarse algunas partículas\n        for (let index_ = index + 2; index_ < particles.length; index_ += 2) {\n          if (connectionCount >= maxConnections) break;\n\n          const dx = particles[index].x - particles[index_].x;\n          const dy = particles[index].y - particles[index_].y;\n          const distanceSq = dx * dx + dy * dy;\n          const maxDistributionSq =\n            CONFIG.connectionDistance * CONFIG.connectionDistance;\n\n          if (distanceSq < maxDistributionSq) {\n            const opacity =\n              1 - Math.sqrt(distanceSq) / CONFIG.connectionDistance;\n            // Reducir la opacidad para un efecto más sutil de universo profundo\n            const universeOpacity = opacity * 0.15 * (CONFIG.starOpacity || 1);\n            lines.push({\n              x1: particles[index].x,\n              y1: particles[index].y,\n              x2: particles[index_].x,\n              y2: particles[index_].y,\n              opacity: universeOpacity,\n            });\n            connectionCount++;\n          }\n        }\n      }\n\n      // Dibujar todas las líneas de una vez\n      for (const line of lines) {\n        context.strokeStyle = `rgba(0, 224, 255, ${line.opacity})`;\n        context.beginPath();\n        context.moveTo(line.x1, line.y1);\n        context.lineTo(line.x2, line.y2);\n        context.stroke();\n      }\n    };\n\n    // Optimización para mejorar el rendimiento\n    let lastFrameTime = 0;\n    const targetFPS = 30; // Limitamos a 30 FPS para ahorrar recursos\n    const frameInterval = 1000 / targetFPS;\n\n    const animate = (timestamp) => {\n      // Limitar la tasa de frames para optimizar rendimiento\n      const elapsed = timestamp - lastFrameTime;\n\n      if (elapsed > frameInterval) {\n        lastFrameTime = timestamp - (elapsed % frameInterval);\n\n        context.clearRect(0, 0, canvas.width, canvas.height);\n        for (const p of particles) p.update();\n        drawConnections();\n        for (const p of particles) p.draw();\n      }\n\n      animationReference.current = requestAnimationFrame(animate);\n    };\n\n    // Iniciar la animación\n    animationReference.current = requestAnimationFrame(animate);\n\n    let ticking = false;\n    const handleMouseMove = (e) => {\n      if (!ticking) {\n        requestAnimationFrame(() => {\n          mousePosition.current = { x: e.clientX, y: e.clientY };\n          ticking = false;\n        });\n        ticking = true;\n      }\n    };\n\n    const handleTouchMove = (e) => {\n      if (e.touches && e.touches[0]) {\n        mousePosition.current = {\n          x: e.touches[0].clientX,\n          y: e.touches[0].clientY,\n        };\n      }\n    };\n\n    globalThis.addEventListener('mousemove', handleMouseMove);\n    globalThis.addEventListener('touchmove', handleTouchMove);\n\n    // Función de limpieza del efecto\n    return () => {\n      if (animationReference.current) {\n        cancelAnimationFrame(animationReference.current);\n        animationReference.current = null;\n      }\n      globalThis.removeEventListener('mousemove', handleMouseMove);\n      globalThis.removeEventListener('touchmove', handleTouchMove);\n    };\n  }, [isUltraMode, width, height]); // La dependencia clave es isUltraMode\n\n  // Renderizado unificado: la estructura JSX es siempre la misma.\n  // La visibilidad de los modos se controla con estilos condicionales.\n  return (\n    <div className='ts-background-scene-container' aria-hidden='true'>\n      {/* Modo Ultra: Fondo estático artístico */}\n      <div\n        className='ultra-mode-background'\n        style={{ display: isUltraMode ? 'block' : 'none' }}\n      >\n        <div\n          style={{\n            position: 'absolute',\n            top: 0,\n            left: 0,\n            width: '100%',\n            height: '100%',\n            backgroundColor: 'rgba(0, 0, 0, 0.96)',\n            zIndex: 0,\n            pointerEvents: 'none',\n          }}\n        />\n        <div\n          style={{\n            position: 'absolute',\n            top: 0,\n            left: 0,\n            width: '100%',\n            height: '100%',\n   