,{"ruleId":"jsx-a11y/no-noninteractive-element-interactions","severity":2,"message":"Non-interactive elements should not be assigned mouse or keyboard event listeners.","line":266,"column":15,"nodeType":"JSXOpeningElement","endLine":270,"endColumn":16},{"ruleId":"@typescript-eslint/prefer-nullish-coalescing","severity":2,"message":"Prefer using nullish coalescing operator (`??`) instead of a logical or (`||`), as it is a safer operator.","line":280,"column":46,"nodeType":"Punctuator","messageId":"preferNullishOverOr","endLine":280,"endColumn":48,"suggestions":[{"messageId":"suggestNullish","data":{"equals":""},"fix":{"range":[10266,10268],"text":"??"},"desc":"Fix to nullish coalescing operator (`??`)."}]},{"ruleId":"@typescript-eslint/no-misused-promises","severity":2,"message":"Promise-returning function provided to attribute where a void return was expected.","line":288,"column":23,"nodeType":"JSXExpressionContainer","messageId":"voidReturnAttribute","endLine":288,"endColumn":38}],"suppressedMessages":[],"errorCount":11,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"// src/components/onboarding/nodes/ainode/AiNode.tsx\nimport { Info as InfoIcon } from '@mui/icons-material';\nimport {\n  Cog,\n  Brain,\n  Terminal,\n  Zap,\n  ChevronDown,\n  ChevronUp,\n  Eye,\n  Play,\n} from 'lucide-react';\nimport React, {\n  useState,\n  useCallback,\n  useEffect,\n  useRef,\n  memo,\n  lazy,\n  Suspense,\n} from 'react';\nimport type { NodeProps } from 'reactflow';\nimport { Handle, Position, useUpdateNodeInternals } from 'reactflow';\n\nimport type { AiNodeData } from './types';\nimport './AiNode.css';\n\nconst Tooltip = lazy(async () => import('../../ui/ToolTip'));\nimport { useAINode } from './useAINode';\n\nconst AiNodeComponent: React.FC<NodeProps<AiNodeData>> = ({\n  id,\n  data,\n  selected,\n  isConnectable,\n}) => {\n  const promptTextareaReference = useRef<HTMLTextAreaElement>(null);\n  const {\n    promptTemplate,\n    temperature,\n    maxTokens,\n    systemMessage,\n    responseVariable,\n    // streaming, // Descomentar si se usa\n    ultraMode,\n    isLoading,\n    error,\n    lastResponse,\n    interpolatedPromptPreview,\n    handlePromptChange,\n    handleSettingChange,\n    handleExecute,\n    isCollapsed,\n    handleToggleCollapse: hookHandleToggleCollapse, // Renombrar para evitar conflicto con la función local si existiera\n  } = useAINode({ id, data });\n\n  // Auto-resize for prompt textarea\n  useEffect(() => {\n    if (promptTextareaReference.current) {\n      promptTextareaReference.current.style.height = 'auto';\n      promptTextareaReference.current.style.height = `${promptTextareaReference.current.scrollHeight}px`;\n    }\n  }, [promptTemplate]);\n\n  const [isSettingsExpanded, setIsSettingsExpanded] = useState(true);\n  const [isPreviewExpanded, setIsPreviewExpanded] = useState(false);\n\n  const updateNodeInternals = useUpdateNodeInternals();\n\n  useEffect(() => {\n    updateNodeInternals(id);\n  }, [ultraMode, id, updateNodeInternals]);\n\n  // Helper para manejar cambios de input y pasarlos a handleSettingChange\n  const onSettingChange = (\n    field: keyof AiNodeData,\n    e: React.ChangeEvent<\n      HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement\n    >,\n  ) => {\n    const target = e.target;\n    let value: string | number | boolean;\n    if (target.type === 'number') {\n      value = Number.parseFloat(target.value);\n    } else if (target.type === 'checkbox') {\n      value = (target as HTMLInputElement).checked;\n    } else {\n      // Incluye text, textarea, select\n      value = target.value;\n    }\n    handleSettingChange(field, value);\n  };\n\n  const currentLabel = data.label || 'Nodo IA';\n\n  return (\n    <div\n      className={`ai-node ${isCollapsed ? 'collapsed' : ''} ${ultraMode ? 'ai-node--ultra-performance' : 'ai-node--normal-mode'} ${selected ? 'selected' : ''}`}\n    >\n      <div className='ai-node-header' onClick={hookHandleToggleCollapse}>\n        <h3>{data.label || 'Nodo IA'}</h3>\n        <button className='collapse-toggle'>\n          {isCollapsed ? 'Expandir' : 'Contraer'}\n        </button>\n      </div>\n      {!isCollapsed && (\n        <Suspense fallback={null}>\n          <div className='ai-node-content'>\n            <div className='ainode-section'>\n              <h3 className='ainode-section-title'>\n                <Terminal size={16} /> Prompt Principal\n                <Tooltip\n                  content='Escribe la instrucción principal para la IA. Puedes incluir datos de nodos anteriores usando {{nombre_variable}} o el último mensaje del usuario con {{mensaje_usuario_anterior}}. Ejemplo: El usuario dijo: {{mensaje_usuario_anterior}}. Resume su pedido.'\n                  position='top'\n                  delay={300}\n                >\n                  <InfoIcon\n                    style={{\n                      fontSize: '16px',\n                      marginLeft: '8px',\n                      cursor: 'help',\n                      verticalAlign: 'middle',\n                    }}\n                  />\n                </Tooltip>\n              </h3>\n              <div className='nodrag'>\n                <textarea\n                  className='ainode-textarea'\n                  ref={promptTextareaReference}\n                  value={promptTemplate}\n                  onChange={(e) => handlePromptChange(e.target.value)}\n                  placeholder='Escribe tu prompt aquí. Usa {{variable}} para variables dinámicas.'\n                  rows={4}\n                />\n              </div>\n            </div>\n\n            {isSettingsExpanded && (\n              <div className='ainode-section'>\n                <h3 className='ainode-section-title'>\n                  <Cog size={16} /> Parámetros del Modelo\n                </h3>\n                <div className='ainode-parameter-grid'>\n                  <div className='ainode-parameter-item'>\n                    <label htmlFor={`temp-${id}`}>\n                      Temperatura\n                      <Tooltip\n                        content='Controla la creatividad de la IA. Valores más altos (ej: 0.8) generan respuestas más variadas e inesperadas. Valores bajos (ej: 0.2) producen respuestas más enfocadas y predecibles.'\n                        position='top'\n                        delay={300}\n                      >\n                        <InfoIcon\n                          style={{\n                            fontSize: '14px',\n                            marginLeft: '4px',\n                            cursor: 'help',\n                            verticalAlign: 'middle',\n                          }}\n                        />\n                      </Tooltip>\n                    </label>\n                    <input\n                      id={`temp-${id}`}\n                      type='number'\n                      className='ainode-input'\n                      value={temperature}\n                      onChange={(e) => onSettingChange('temperature', e)}\n                      min='0'\n                      max='2'\n                      step='0.1'\n                    />\n                  </div>\n                  <div className='ainode-parameter-item'>\n                    <label htmlFor={`tokens-${id}`}>\n                      Max Tokens\n                      <Tooltip\n                        content=\"Define la longitud máxima de la respuesta de la IA. Un 'token' es aproximadamente una palabra o parte de una palabra.\"\n                        position='top'\n                        delay={300}\n                      >\n                        <InfoIcon\n                          style={{\n                            fontSize: '14px',\n                            marginLeft: '4px',\n                            cursor: 'help',\n                            verticalAlign: 'middle',\n                          }}\n                        />\n                      </Tooltip>\n                    </label>\n                    <input\n                      id={`tokens-${id}`}\n                      type='number'\n                      className='ainode-input'\n                      value={maxTokens}\n                      onChange={(e) => onSettingChange('maxTokens', e)}\n                      min='1'\n                      step='1'\n                    />\n                  </div>\n                </div>\n                <div\n                  className='ainode-parameter-item'\n                  style={{ marginTop: '10px' }}\n                >\n                  <label htmlFor={`system-${id}`}>\n                    Mensaje de Sistema (Opcional)\n                    <Tooltip\n                      content=\"Instrucción general o rol para la IA (ej: 'Actúa como un experto en historia'). La IA considerará este mensaje junto con el prompt principal. Es opcional.\"\n                      position='top'\n                      delay={300}\n                    >\n                      <InfoIcon\n                        style={{\n                          fontSize: '14px',\n                          marginLeft: '4px',\n                          cursor: 'help',\n                          verticalAlign: 'middle',\n                        }}\n                      />\n                    </Tooltip>\n                  </label>\n                  <div className='nodrag'>\n                    <textarea\n                      id={`system-${id}`}\n                      className='ainode-textarea'\n                      value={systemMessage || ''}\n                      onChange={(e) => onSettingChange('systemMessage', e)}\n                      placeholder='Ej: Eres un asistente experto en marketing...'\n                      rows={2}\n                    />\n                  </div>\n                </div>\n              </div>\n            )}\n\n            <div className='ainode-section'>\n              <h3 className='ainode-section-title'>\n                <Zap size={16} /> Variable de Salida\n                <Tooltip\n                  content='Aquí se guardará la respuesta de la IA. Podrás usar esta respuesta en nodos posteriores escribiendo {{nombre_de_esta_variable}} (ej: {{ai_response}}) en sus prompts o campos.'\n                  position='top'\n                  delay={300}\n                >\n                  <InfoIcon\n                    style={{\n                      fontSize: '16px',\n                      marginLeft: '8px',\n                      cursor: 'help',\n                      verticalAlign: 'middle',\n                    }}\n                  />\n                </Tooltip>\n              </h3>\n              <input\n                type='text'\n                className='ainode-input'\n                value={responseVariable}\n                onChange={(e) => onSettingChange('responseVariable', e)}\n                placeholder='Ej: respuestaIA, contenidoGenerado'\n              />\n            </div>\n\n            <div className='ainode-section'>\n              <h3\n                className='ainode-section-title'\n                style={{ cursor: 'pointer' }}\n                onClick={() => setIsPreviewExpanded(!isPreviewExpanded)}\n              >\n                <Eye size={16} /> Vista Previa del Prompt Interpolado{' '}\n                {isPreviewExpanded ? (\n                  <ChevronUp size={16} />\n                ) : (\n                  <ChevronDown size={16} />\n                )}\n              </h3>\n              {isPreviewExpanded && (\n                <div className='ainode-response-preview'>\n                  {interpolatedPromptPreview ||\n                    'La vista previa aparecerá aquí cuando se interpelen las variables.'}\n                </div>\n              )}\n            </div>\n\n            <button\n              className='ainode-button'\n              onClick={handleExecute}\n              disabled={isLoading}\n            >\n              <Play size={16} style={{ marginRight: '8px' }} />\n              {isLoading ? 'Procesando...' : 'Probar Ahora'}\n            </button>\n\n            {isLoading && (\n              <div className='ainode-status-indicator ainode-status-loading'>\n                Procesando IA...\n              </div>\n            )}\n            {error && (\n              <div className='ainode-status-indicator ainode-status-error'>\n                {error}\n              </div>\n            )}\n            {lastResponse && !isLoading && !error && (\n              <div className='ainode-status-indicator ainode-status-success'>\n                Respuesta recibida:\n                <div\n                  className='ainode-response-preview'\n                  style={{\n                    maxHeight: '60px',\n                    marginTop: '5px',\n                    background: 'rgba(255,255,255,0.05)',\n                  }}\n                >\n                  {lastResponse}\n                </div>\n              </div>\n            )}\n          </div>\n        </Suspense>\n      )}\n      <Handle\n        type='target'\n        position={Position.Left}\n        id='input'\n        className='node-handle ai-node__handle'\n        isConnectable={isConnectable}\n      />\n      <Handle\n        type='source'\n        position={Position.Right}\n        id='output'\n        className='node-handle ai-node__handle'\n        isConnectable={isConnectable}\n      />\n    </div>\n  );\n};\n\nconst arePropertiesEqual = (\n  previousProperties: NodeProps<AiNodeData>,\n  nextProperties: NodeProps<AiNodeData>,\n) => {\n  // Comparación superficial de las propiedades de 'data' que afectan la UI.\n  const dataChanged =\n    Object.keys(previousProperties.data).length !==\n      Object.keys(nextProperties.data).length ||\n    Object.keys(previousProperties.data).some(\n      (key) =>\n        previousProperties.data[key as keyof AiNodeData] !==\n        nextProperties.data[key as keyof AiNodeData],\n    );\n\n  // Re-renderizar solo si 'selected' o los datos relevantes han cambiado.\n  return (\n    previousProperties.selected === nextProperties.selected && !dataChanged\n  );\n};\n\nconst AiNode = memo(AiNodeComponent, arePropertiesEqual);\n\nAiNode.displayName = 'AiNode';\n\nexport default AiNode;\n","usedDeprecatedRules":[{"ruleId":"@typescript-eslint/no-loss-of-precision","replacedBy":["no-loss-of-precision"],"info":{"deprecatedSince":"8.0.0","replacedBy":[{"rule":{"name":"no-loss-of-precision","url":"https://eslint.org/docs/latest/rules/no-loss-of-precision"}}],"url":"https://github.com/typescript-eslint/typescript-eslint/pull/8832"}},{"ruleId":"@typescript-eslint/prefer-ts-expect-error","replacedBy":["@typescript-eslint/ban-ts-comment"],"info":{"deprecatedSince":"7.11.0","replacedBy":[{"rule":{"name":"@typescript-eslint/ban-ts-comment","url":"https://typescript-eslint.io/rules/ban-ts-comment"}}],"url":"https://github.com/typescript-eslint/typescript-eslint/pull/9081"}}]},{"filePath":"/Users/wolf/Desktop/Plubot/plubot-frontend/src/components/onboarding/nodes/ainode/index.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[{"ruleId":"@typescript-eslint/no-loss-of-precision","replacedBy":["no-loss-of-precision"],"info":{"deprecatedSince":"8.0.0","replacedBy":[{"rule":{"name":"no-loss-of-precision","url":"https://eslint.org/docs/latest/rules/no-loss-of-precision"}}],"url":"https://github.com/typescript-eslint/typescript-eslint/pull/8832"}},{"ruleId":"@typescript-eslint/prefer-ts-expect-error","replacedBy":["@typescript-eslint/ban-ts-comment"],"info":{"deprecatedSince":"7.11.0","replacedBy":[{"rule":{"name":"@typescript-eslint/ban-ts-comment","url":"https://typescript-eslint.io/rules/ban-ts-comment"}}],"url":"https://github.com/typescript-eslint/typescript-eslint/pull/9081"}}]},{"filePath":"/Users/wolf/Desktop/Plubot/plubot-frontend/src/component