import React, { useState, useEffect, useCallback, useRef, Suspense, lazy } from 'react';
import { applyNodeChanges, applyEdgeChanges } from 'reactflow';
import { debounce } from 'lodash';
import { useNavigate, useSearchParams, useParams } from 'react-router-dom';
import ReactFlow from 'reactflow';
import 'reactflow/dist/style.css';
import { usePlubotCreation } from '@/context/PlubotCreationContext';
import { useGamification } from '@/context/GamificationContext';
import useDebounce from '@/hooks/useDebounce';

// Importar stores de manera diferida para evitar errores de inicialización
import useFlowStore from '@/stores/useFlowStore';
import useTrainingStore from '@/stores/useTrainingStore';

const loadStores = () => {
  try {
    return { flowStore: useFlowStore, trainingStore: useTrainingStore };
  } catch (error) {
    console.error('[TrainingScreen] Error al cargar stores:', error);
    return { flowStore: null, trainingStore: null };
  }
};

// Función para obtener el store de manera segura
const getFlowStore = () => {
  try {
    return useFlowStore;
  } catch (error) {
    console.error('[TrainingScreen] Error al obtener FlowStore:', error);
    return null;
  }
};

const getTrainingStore = () => {
  try {
    return useTrainingStore;
  } catch (error) {
    console.error('[TrainingScreen] Error al obtener TrainingStore:', error);
    return null;
  }
};

// Hook para forzar la actualización del componente
const useForceUpdate = () => {
  const [, forceUpdate] = React.useReducer(x => x + 1, 0);
  return forceUpdate;
};

// Importar componentes
import FlowEditor from '../flow-editor/FlowEditor.jsx';
import NodePalette from '../common/NodePalette';
import ByteAssistant from '../common/ByteAssistant';
import StatusBubble from '../common/StatusBubble';
import logo from '@/assets/img/plubot.svg';
import './TrainingScreen.css';
import '../styles/responsive.css'; // Estilos responsivos para todos los componentes
import '../fix-global.css'; // CSS global para eliminar overlays oscuros y mensajes duplicados

// Importar utilidades para manejar aristas
import { 
  ensureEdgesAreVisible, 
  recoverEdgesFromLocalStorage, 
  forceEdgesUpdate,
  validateEdges
} from '../flow-editor/utils/edgeFixUtil';

// Lazy-loaded components
const TemplateSelector = lazy(() => import('../modals/TemplateSelector'));
const ImportExportModal = lazy(() => import('../modals/ImportExportModal'));
const ConnectionEditor = lazy(() => import('../simulation/ConnectionEditor'));
const RouteAnalysisPanel = lazy(() => import('../common/RouteAnalysisPanel'));
const VersionHistory = lazy(() => import('../common/VersionHistory'));
const SuggestionsModal = lazy(() => import('../modals/SuggestionsModal'));
const EmbedModal = lazy(() => import('../modals/EmbedModal'));

// Modal Manager to handle conditional rendering of modals
const ModalManager = ({ modals, modalProps, onClose }) => (
  <>
    {modals.showTemplateSelector && (
      <Suspense fallback={<div>Loading...</div>}>
        <TemplateSelector {...modalProps.templateSelector} onClose={() => onClose('showTemplateSelector')} />
      </Suspense>
    )}
    {modals.showExportMode && (
      <Suspense fallback={<div>Loading...</div>}>
        <ImportExportModal {...modalProps.importExport} onClose={() => onClose('showExportMode')} />
      </Suspense>
    )}
    {modals.showConnectionEditor && (
      <Suspense fallback={<div>Loading...</div>}>
        <ConnectionEditor {...modalProps.connectionEditor} onClose={() => onClose('showConnectionEditor')} />
      </Suspense>
    )}
    {modals.showRouteAnalysis && (
      <Suspense fallback={<div>Loading...</div>}>
        <RouteAnalysisPanel {...modalProps.routeAnalysis} onClose={() => onClose('showRouteAnalysis')} />
      </Suspense>
    )}
    {modals.showSuggestionsModal && (
      <Suspense fallback={<div>Loading...</div>}>
        <SuggestionsModal {...modalProps.suggestionsModal} onClose={() => onClose('showSuggestionsModal')} />
      </Suspense>
    )}
    {modals.showEmbedModal && (
      <Suspense fallback={<div>Loading...</div>}>
        <EmbedModal {...modalProps.embedModal} onClose={() => onClose('showEmbedModal')} />
      </Suspense>
    )}
  </>
);

// Función para procesar los datos del plubot
const processPlubotData = (plubotData) => {
  try {
    if (!plubotData) {
      console.error('[processPlubotData] No se proporcionaron datos del plubot');
      return null;
    }
    
    console.log('[processPlubotData] Procesando datos del plubot:', plubotData);
    
    // Extraer nodos y aristas del flujo de trabajo
    const workflowData = plubotData.workflow || {};
    const rawNodes = workflowData.nodes || [];
    const rawEdges = workflowData.edges || [];
    
    // Mapear los nodos al formato esperado por React Flow
    const nodes = rawNodes.map(node => ({
      id: node.id || `node-${Math.random().toString(36).substr(2, 9)}`,
      type: node.type || 'default',
      position: node.position || { x: 0, y: 0 },
      data: {
        ...node.data,
        label: node.data?.label || `Nodo ${node.type || 'sin tipo'}`
      }
    }));
    
    // Mapear las aristas al formato esperado por React Flow
    const edges = rawEdges.map(edge => ({
      id: edge.id || `edge-${Math.random().toString(36).substr(2, 9)}`,
      source: edge.source,
      target: edge.target,
      type: edge.type || 'default',
      animated: edge.animated || false,
      data: edge.data || {}
    }));
    
    console.log('[processPlubotData] Datos procesados:', { nodes, edges });
    
    return {
      nodes,
      edges,
      name: plubotData.name || 'Flujo sin nombre'
    };
    
  } catch (error) {
    console.error('[processPlubotData] Error al procesar los datos del plubot:', error);
    return null;
  }
};

// Componente envoltorio seguro que evita errores de inicialización
const SafeTrainingScreen = () => {
  // Estado para controlar si el componente está listo para renderizarse
  const [isReady, setIsReady] = useState(false);
  const [error, setError] = useState(null);
  const [storesLoaded, setStoresLoaded] = useState(false);
  
  // Intentar cargar los stores de manera segura
  useEffect(() => {
    try {
      // Verificar si los stores están disponibles
      const { flowStore, trainingStore } = loadStores();
      if (flowStore && trainingStore) {
        console.log('[SafeTrainingScreen] Stores cargados correctamente');
        setStoresLoaded(true);
        setIsReady(true);
      } else {
        console.error('[SafeTrainingScreen] No se pudieron cargar los stores');
        setError('No se pudieron cargar los stores necesarios');
      }
    } catch (error) {
      console.error('[SafeTrainingScreen] Error al cargar los stores:', error);
      setError(error.message || 'Error desconocido al cargar los stores');
    }
  }, []);
  
  // Si hay un error, mostrar pantalla de error
  if (error) {
    return (
      <div className="ts-error-screen">
        <img src={logo} alt="Logo" className="ts-loading-logo" />
        <h2>Error al cargar el editor de flujo</h2>
        <p>{error}</p>
        <button onClick={() => window.location.reload()} className="ts-reload-btn">
          Recargar página
        </button>
      </div>
    );
  }
  
  // Si los stores no están cargados, mostrar pantalla de carga
  if (!storesLoaded) {
    return (
      <div className="ts-loading-screen">
        <img src={logo} alt="Logo" className="ts-loading-logo" />
        <h2>Inicializando editor de flujo...</h2>
        <div className="ts-loading-spinner"></div>
        <p>Cargando componentes y funcionalidades...</p>
      </div>
    );
  }
  
  // Renderizar el componente interno con manejo de errores
  return (
    <ErrorBoundary
      fallback={(
        <div className="ts-error-screen">
          <img src={logo} alt="Logo" className="ts-loading-logo" />
          <h2>Error al cargar el editor de flujo</h2>
          <p>Ha ocurrido un error al inicializar el editor. Por favor, intenta recargar la página.</p>
          <button onClick={() => window.location.reload()} className="ts-reload-btn">
            Recargar página
          </button>
        </div>
      )}
    >
      <Suspense fallback={
        <div className="ts-loading-screen">
          <img src={logo} alt="Logo" className="ts-loading-logo" />
          <h2>Cargando editor de flujo...</h2>
          <div className="ts-loading-spinner"></div>
        </div>
      }>
        <TrainingScreenInner />
      </Suspense>
    </ErrorBoundary>
  );
};

// Componente interno que implementa la lógica real
const TrainingScreenInner = () => {
  // Usar un estado para forzar re-renderizados controlados
  const [renderKey, setRenderKey] = useState(Date.now());
  
  // Obtener el estado y las acciones de los stores de Zustand
  const {
    nodes,
    edges,
    flowName,
    selectedNode,
    selectedEdge,
    isUltraMode,
    setNodes,
    setEdges,
    setFlowName,
    onNodesChange,
    onEdgesChange,
    onConnect,
    toggleUltraMode,
    undo,
    redo,
    canUndo,
    canRedo
  } = useFlowStore();
  
  const {
    plubotData,
    isLoading,
    error,
    byteMessage,
    showSimulation,
    showTemplateSelector,
    showExportMode,
    showConnectionEditor,
    showRouteAnalysis,
    showVersionHistoryPanel,
    showSuggestionsModal,
    showEmbedModal,
    selectedConnection,
    connectionProperties,
    nodeSuggestions,
    routeAnalysisData,
    importData,
    exportFormat,
    setPlubotData,
    setIsLoading,
    setError,
    setByteMessage,
    setShowSimulation,
    setShowTemplateSelector,
    setShowExportMode,
    setShowConnectionEditor,
    setShowRouteAnalysis,
    setShowVersionHistoryPanel,
    setShowSuggestionsModal,
    setShowEmbedModal,
    setSelectedConnection,
    setConnectionProperties,
    setNodeSuggestions,
    setRouteAnalysisData,
    setImportData,
    setExportFormat,
  } = useTrainingStore();
  
  // Estado para controlar si el componente está listo para renderizarse
  const [isComponentReady, setIsComponentReady] = useState(false);
  
  // Función para manejar la selección de plantillas de manera segura
  const handleSelectTemplate = useCallback((template) => {
    console.log('[TrainingScreen] Plantilla seleccionada:', template);
    
    if (!template || !template.nodes) {
      console.error('[TrainingScreen] Plantilla inválida:', template);
      setByteMessage('❌ Error: Plantilla inválida o incompleta');
      setTimeout(() => setByteMessage(''), 3000);
      return;
    }
    
    try {
      // Actualizar nodos y aristas con los de la plantilla
      setNodes(template.nodes || []);
      setEdges(template.edges || []);
      setFlowName(template.name || 'Nuevo flujo');
      setByteMessage('✅ Plantilla aplicada correctamente');
      
      // Cerrar el selector de plantillas
      setShowTemplateSelector(false);
      
      // Limpiar mensaje después de un tiempo
      setTimeout(() => setByteMessage(''), 3000);
      
    } catch (error) {
      console.error('[TrainingScreen] Error al aplicar plantilla:', error);
      setByteMessage('❌ Error al aplicar la plantilla');
      setTimeout(() => setByteMessage(''), 3000);
    }
  }, [setNodes, setEdges, setFlowName, setByteMessage, setShowTemplateSelector]);
  
  // Función para analizar el flujo actual
  const analyzeFlow = useCallback(() => {
    try {
      console.log('[TrainingScreen] Analizando flujo...');
      
      // Verificar si hay nodos y aristas
      if (nodes.length === 0) {
        const result = {
          status: 'warning',
          message: 'El flujo está vacío. Agrega nodos para comenzar.',
          details: []
        };
        
        // Actualizar los datos de análisis y mostrar el panel
        setRouteAnalysisData(result);
        setShowRouteAnalysis(true);
        
        return result;
      }
      
      // Análisis básico del flujo
      const startNodes = nodes.filter(node => 
        node.type === 'startNode' || 
        (node.id && typeof node.id === 'string' && node.id.includes('start')));
      
      const endNodes = nodes.filter(node => 
        node.type === 'endNode' || 
        (node.id && typeof node.id === 'string' && node.id.includes('end')));
      
      const messageNodes = nodes.filter(node => 
        node.type === 'messageNode' || 
        (node.id && typeof node.id === 'string' && node.id.includes('message')));
      
      const conditionNodes = nodes.filter(node => 
        node.type === 'conditionNode' || 
        (node.id && typeof node.id === 'string' && node.id.includes('condition')));
      
      // Verificar rutas y conexiones
      const nodesWithoutOutgoingEdges = nodes.filter(node => {
        // Excluir nodos finales que no necesitan conexiones salientes
        if (node.type === 'endNode' || (node.id && typeof node.id === 'string' && node.id.includes('end'))) return false;
        return !edges.some(edge => edge.source === node.id);
      });
      
      const nodesWithoutIncomingEdges = nodes.filter(node => {
        // Excluir nodos iniciales que no necesitan conexiones entrantes
        if (node.type === 'startNode' || (node.id && typeof node.id === 'string' && node.id.includes('start'))) return false;
        return !edges.some(edge => edge.target === node.id);
      });
      
      // Preparar resultados del análisis
      const details = [
        `Nodos totales: ${nodes.length}`,
        `Conexiones totales: ${edges.length}`,
        `Nodos de inicio: ${startNodes.length}`,
        `Nodos de fin: ${endNodes.length}`,
        `Nodos de mensaje: ${messageNodes.length}`,
        `Nodos de condición: ${conditionNodes.length}`
      ];
      
      // Agregar advertencias si es necesario
      if (nodesWithoutOutgoingEdges.length > 0) {
        details.push(`Advertencia: ${nodesWithoutOutgoingEdges.length} nodos sin conexiones salientes`);
      }
      
      if (nodesWithoutIncomingEdges.length > 0 && nodesWithoutIncomingEdges.length > startNodes.length) {
        details.push(`Advertencia: ${nodesWithoutIncomingEdges.length - startNodes.length} nodos sin conexiones entrantes`);
      }
      
      // Determinar el estado general del análisis
      let status = 'success';
      let message = 'El flujo parece estar correctamente configurado.';
      
      if (nodesWithoutOutgoingEdges.length > 0 || (nodesWithoutIncomingEdges.length > 0 && nodesWithoutIncomingEdges.length > startNodes.length)) {
        status = 'warning';
        message = 'El flujo tiene algunas advertencias que podrían afectar su funcionamiento.';
      }
      
      if (startNodes.length === 0) {
        status = 'error';
        message = 'El flujo no tiene un nodo de inicio. Agrega un nodo de inicio para comenzar.';
      }
      
      if (endNodes.length === 0) {
        status = status === 'error' ? status : 'warning';
        message = status === 'error' ? message : 'El flujo no tiene un nodo de fin. Considera agregar un nodo de fin para completar el flujo.';
      }
      
      const result = {
        status,
        message,
        details
      };
      
      // Actualizar los datos de análisis y mostrar el panel
      setRouteAnalysisData(result);
      setShowRouteAnalysis(true);
      
      console.log('[TrainingScreen] Análisis completado:', result);
      return result;
    } catch (error) {
      console.error('[TrainingScreen] Error al analizar el flujo:', error);
      const result = {
        status: 'error',
        message: 'Error al analizar el flujo: ' + (error.message || 'Error desconocido'),
        details: []
      };
      
      // Actualizar los datos de análisis y mostrar el panel incluso en caso de error
      setRouteAnalysisData(result);
      setShowRouteAnalysis(true);
      
      return result;
    }
  }, [nodes, edges, setRouteAnalysisData, setShowRouteAnalysis]);
  
  // Función para generar sugerencias basadas en el flujo actual
  const generateSuggestions = useCallback(() => {
    try {
      console.log('[TrainingScreen] Generando sugerencias...');
      
      // Verificar si hay nodos para generar sugerencias
      if (nodes.length === 0) {
        const suggestions = [
          {
            id: 'start-suggestion',
            type: 'start',
            title: 'Agregar nodo de inicio',
            description: 'Comienza tu flujo con un nodo de inicio para establecer el punto de entrada.',
            confidence: 0.95
          }
        ];
        
        // Actualizar sugerencias y mostrar el modal
        setNodeSuggestions(suggestions);
        setShowSuggestionsModal(true);
        
        return suggestions;
      }
      
      // Analizar el flujo para identificar posibles mejoras
      const startNodes = nodes.filter(node => 
        node.type === 'startNode' || 
        (node.id && typeof node.id === 'string' && node.id.includes('start')));
      
      const endNodes = nodes.filter(node => 
        node.type === 'endNode' || 
        (node.id && typeof node.id === 'string' && node.id.includes('end')));
      
      const suggestions = [];
      
      // Sugerir nodo de inicio si no existe
      if (startNodes.length === 0) {
        suggestions.push({
          id: 'start-suggestion',
          type: 'start',
          title: 'Agregar nodo de inicio',
          description: 'Tu flujo necesita un nodo de inicio para establecer el punto de entrada.',
          confidence: 0.95
        });
      }
      
      // Sugerir nodo de fin si no existe
      if (endNodes.length === 0) {
        suggestions.push({
          id: 'end-suggestion',
          type: 'end',
          title: 'Agregar nodo de fin',
          description: 'Completa tu flujo con un nodo de fin para establecer un punto de salida claro.',
          confidence: 0.9
        });
      }
      
      // Identificar nodos sin conexiones salientes (excepto nodos de fin)
      const nodesWithoutOutgoingEdges = nodes.filter(node => {
        // Excluir nodos finales que no necesitan conexiones salientes
        if (node.type === 'endNode' || (node.id && typeof node.id === 'string' && node.id.includes('end'))) return false;
        return !edges.some(edge => edge.source === node.id);
      });
      
      // Sugerir conexiones para nodos sin salidas
      if (nodesWithoutOutgoingEdges.length > 0) {
        nodesWithoutOutgoingEdges.forEach(node => {
          suggestions.push({
            id: `connect-${node.id}`,
            type: 'connection',
            title: `Conectar nodo ${node.id}`,
            description: `Este nodo no tiene conexiones salientes. Considera conectarlo a otro nodo para completar el flujo.`,
            confidence: 0.85,
            nodeId: node.id
          });
        });
      }
      
      // Identificar nodos sin conexiones entrantes (excepto nodos de inicio)
      const nodesWithoutIncomingEdges = nodes.filter(node => {
        // Excluir nodos iniciales que no necesitan conexiones entrantes
        if (node.type === 'startNode' || (node.id && typeof node.id === 'string' && node.id.includes('start'))) return false;
        return !edges.some(edge => edge.target === node.id);
      });
      
      // Sugerir conexiones para nodos sin entradas
      if (nodesWithoutIncomingEdges.length > 0) {
        nodesWithoutIncomingEdges.forEach(node => {
          suggestions.push({
            id: `connect-to-${node.id}`,
            type: 'connection',
            title: `Conectar hacia nodo ${node.id}`,
            description: `Este nodo no tiene conexiones entrantes. Considera conectarlo desde otro nodo para integrarlo al flujo.`,
            confidence: 0.8,
            nodeId: node.id
          });
        });
      }
      
      // Sugerir nodos de condición si el flujo es lineal
      const conditionNodes = nodes.filter(node => 
        node.type === 'conditionNode' || 
        (node.id && typeof node.id === 'string' && node.id.includes('condition')));
      
      if (conditionNodes.length === 0 && nodes.length > 3) {
        suggestions.push({
          id: 'condition-suggestion',
          type: 'condition',
          title: 'Agregar nodo de condición',
          description: 'Tu flujo parece ser lineal. Considera agregar nodos de condición para crear ramificaciones y hacer tu flujo más dinámico.',
          confidence: 0.75
        });
      }
      
      // Actualizar sugerencias y mostrar el modal
      setNodeSuggestions(suggestions);
      setShowSuggestionsModal(true);
      
      console.log('[TrainingScreen] Sugerencias generadas:', suggestions);
      return suggestions;
    } catch (error) {
      console.error('[TrainingScreen] Error al generar sugerencias:', error);
      setByteMessage('❌ Error al generar sugerencias');
      setTimeout(() => setByteMessage(''), 3000);
      return [];
    }
  }, [nodes, edges, setNodeSuggestions, setShowSuggestionsModal, setByteMessage]);
  
  // Función para guardar el flujo actual
  const handleSaveFlow = useCallback(async () => {
    try {
      console.log('[TrainingScreen] Guardando flujo...');
      setIsLoading(true);
      setByteMessage('💾 Guardando flujo...');
      
      // Verificar si hay datos para guardar
      if (nodes.length === 0) {
        setIsLoading(false);
        setByteMessage('⚠️ No hay nodos para guardar');
        setTimeout(() => setByteMessage(''), 3000);
        return false;
      }
      
      // Crear una copia de los datos para evitar problemas de referencia
      const flowData = {
        nodes: JSON.parse(JSON.stringify(nodes)),
        edges: JSON.parse(JSON.stringify(edges)),
        name: flowName
      };
      
      // Simular una llamada a la API (en producción, esto sería una llamada real)
      // En un entorno real, aquí se enviarían los datos al backend
      await new Promise(resolve => setTimeout(resolve, 500));
      
      // Guardar en localStorage como respaldo
      try {
        localStorage.setItem('plubot_flow_backup', JSON.stringify(flowData));
        console.log('[TrainingScreen] Flujo guardado en localStorage como respaldo');
        
        // Guardar específicamente las aristas para la recuperación
        backupEdgesToLocalStorage(edges);
      } catch (storageError) {
        console.warn('[TrainingScreen] No se pudo guardar en localStorage:', storageError);
      }
      
      // Actualizar estado y mostrar mensaje de éxito
      setIsLoading(false);
      setByteMessage('✅ Flujo guardado correctamente');
      
      // Limpiar mensaje después de un tiempo
      setTimeout(() => {
        setByteMessage('');
      }, 3000);
      
      console.log('[TrainingScreen] Flujo guardado correctamente');
      return true;
    } catch (error) {
      console.error('[TrainingScreen] Error al guardar el flujo:', error);
      
      // Actualizar estado y mostrar mensaje de error
      setIsLoading(false);
      setByteMessage('❌ Error al guardar el flujo: ' + (error.message || 'Error desconocido'));
      
      // Limpiar mensaje después de un tiempo
      setTimeout(() => {
        setByteMessage('');
      }, 5000);
      
      return false;
    }
  }, [nodes, edges, flowName, setIsLoading, setByteMessage, backupEdgesToLocalStorage]);
  
  // Función para deshacer la última acción
  const handleUndo = useCallback(() => {
    if (!canUndo) {
      console.log('[TrainingScreen] No hay acciones para deshacer');
      setByteMessage('⚠️ No hay acciones para deshacer');
      setTimeout(() => setByteMessage(''), 3000);
      return;
    }
    
    try {
      // Llamar a la función undo del store
      undo();
      
      // Mostrar mensaje de éxito
      setByteMessage('⏪ Acción deshecha');
      setTimeout(() => setByteMessage(''), 3000);
      console.log('[TrainingScreen] Acción deshecha');
    } catch (error) {
      console.error('[TrainingScreen] Error al deshacer acción:', error);
      setByteMessage('❌ Error al deshacer acción');
      setTimeout(() => setByteMessage(''), 3000);
    }
  }, [undo, canUndo, setByteMessage]);
  
  // Función para rehacer la última acción deshecha
  const handleRedo = useCallback(() => {
    if (!canRedo) {
      console.log('[TrainingScreen] No hay acciones para rehacer');
      setByteMessage('⚠️ No hay acciones para rehacer');
      setTimeout(() => setByteMessage(''), 3000);
      return;
    }
    
    try {
      // Llamar a la función redo del store
      redo();
      
      // Mostrar mensaje de éxito
      setByteMessage('⏩ Acción rehecha');
      setTimeout(() => setByteMessage(''), 3000);
      console.log('[TrainingScreen] Acción rehecha');
    } catch (error) {
      console.error('[TrainingScreen] Error al rehacer acción:', error);
      setByteMessage('❌ Error al rehacer acción');
      setTimeout(() => setByteMessage(''), 3000);
    }
  }, [redo, canRedo, setByteMessage]);
  
  // Función para activar/desactivar el modo ultra
  const handleToggleUltraMode = useCallback(() => {
    try {
      // Llamar a la función del store
      toggleUltraMode();
      
      // Mostrar mensaje de confirmación
      const newMode = !isUltraMode; // El valor opuesto al actual
      console.log(`[TrainingScreen] Modo ultra ${newMode ? 'activado' : 'desactivado'}`);
      setByteMessage(newMode ? '🔥 Modo ultra activado' : '🔥 Modo ultra desactivado');
      setTimeout(() => setByteMessage(''), 3000);
    } catch (error) {
      console.error('[TrainingScreen] Error al cambiar modo ultra:', error);
      setByteMessage('❌ Error al cambiar modo ultra');
      setTimeout(() => setByteMessage(''), 3000);
    }
  }, [toggleUltraMode, isUltraMode, setByteMessage]);
  
  // Función para activar/desactivar el modo de simulación
  const handleToggleSimulation = useCallback(() => {
    try {
      // Cambiar el estado en el store
      setShowSimulation(!showSimulation);
      
      // Mostrar mensaje de confirmación
      const newShow = !showSimulation; // El valor opuesto al actual
      console.log(`[TrainingScreen] Simulación ${newShow ? 'activada' : 'desactivada'}`);
      setByteMessage(newShow ? '💬 Simulación activada' : '💬 Simulación desactivada');
      setTimeout(() => setByteMessage(''), 3000);
    } catch (error) {
      console.error('[TrainingScreen] Error al cambiar modo simulación:', error);
      setByteMessage('❌ Error al cambiar modo simulación');
      setTimeout(() => setByteMessage(''), 3000);
    }
  }, [showSimulation, setShowSimulation, setByteMessage]);
  
  // Nota: Ya no necesitamos definir funciones para controlar los modales
  // ya que estamos usando directamente las funciones del store de Zustand
  
  // Nota: Ya no necesitamos declarar selectedConnection y connectionProperties como estado local
  // ya que los estamos obteniendo directamente del store de Zustand
  
  // Nota: Ya no necesitamos declarar importData y exportFormat como estado local
  // ya que los estamos obteniendo directamente del store de Zustand
  
  // Nota: Ya no necesitamos declarar routeAnalysisData y nodeSuggestions como estado local
  // ya que los estamos obteniendo directamente del store de Zustand
  
  // Función para importar datos al store
  const handleImportFromStore = useCallback((data) => {
    try {
      console.log('[TrainingScreen] Importando datos:', data);
      if (!data) {
        setByteMessage('⚠️ No hay datos para importar');
        setTimeout(() => setByteMessage(''), 3000);
        return false;
      }
      
      let parsedData;
      try {
        parsedData = JSON.parse(data);
      } catch (parseError) {
        console.error('[TrainingScreen] Error al parsear datos de importación:', parseError);
        setByteMessage('❌ Formato de datos inválido');
        setTimeout(() => setByteMessage(''), 3000);
        return false;
      }
      
      if (!parsedData.nodes || !Array.isArray(parsedData.nodes)) {
        setByteMessage('❌ Datos de importación inválidos: no contienen nodos');
        setTimeout(() => setByteMessage(''), 3000);
        return false;
      }
      
      // Actualizar el estado con los datos importados usando las funciones del store
      setNodes(parsedData.nodes || []);
      setEdges(parsedData.edges || []);
      setFlowName(parsedData.name || 'Flujo importado');
      setByteMessage('✅ Datos importados correctamente');
      
      // Cerrar el modal de importación/exportación
      setShowExportMode(false);
      
      // Limpiar mensaje después de un tiempo
      setTimeout(() => setByteMessage(''), 3000);
      
      // Guardar una copia de los datos importados en el store
      setImportData(data);
      
      console.log('[TrainingScreen] Datos importados correctamente');
      return true;
    } catch (error) {
      console.error('[TrainingScreen] Error al importar datos:', error);
      setByteMessage('❌ Error al importar datos: ' + (error.message || 'Error desconocido'));
      setTimeout(() => setByteMessage(''), 3000);
      return false;
    }
  }, [setNodes, setEdges, setFlowName, setByteMessage, setShowExportMode, setImportData]);
  
  // Función para exportar datos desde el store
  const handleExportFromStore = useCallback((format = 'json') => {
    try {
      console.log('[TrainingScreen] Exportando datos en formato:', format);
      
      // Verificar si hay datos para exportar
      if (nodes.length === 0) {
        setByteMessage('⚠️ No hay nodos para exportar');
        setTimeout(() => setByteMessage(''), 3000);
        return null;
      }
      
      // Crear una copia de los datos para evitar problemas de referencia
      const flowData = {
        nodes: JSON.parse(JSON.stringify(nodes)),
        edges: JSON.parse(JSON.stringify(edges)),
        name: flowName
      };
      
      // Actualizar el formato de exportación en el store
      setExportFormat(format);
      
      // Exportar según el formato solicitado
      let exportedData;
      switch (format.toLowerCase()) {
        case 'json':
          exportedData = JSON.stringify(flowData, null, 2);
          break;
        case 'yaml':
        case 'yml':
          // Simulamos conversión a YAML (en producción se usaría una biblioteca real)
          exportedData = `# Flujo: ${flowName}\n` +
            `nodes: ${nodes.length}\n` +
            `edges: ${edges.length}\n` +
            `# Este es un formato YAML simplificado, en producción se usaría una conversión real`;
          break;
        default:
          exportedData = JSON.stringify(flowData, null, 2);
      }
      
      // Actualizar el estado con éxito
      setByteMessage('✅ Datos exportados correctamente');
      
      // Limpiar mensaje después de un tiempo
      setTimeout(() => setByteMessage(''), 3000);
      
      console.log('[TrainingScreen] Datos exportados correctamente');
      return exportedData;
    } catch (error) {
      console.error('[TrainingScreen] Error al exportar datos:', error);
      setByteMessage('❌ Error al exportar datos: ' + (error.message || 'Error desconocido'));
      setTimeout(() => setByteMessage(''), 3000);
      return null;
    }
  }, [nodes, edges, flowName, setByteMessage, setExportFormat]);
  
  // Nota: Ya no necesitamos definir las funciones onNodesChange y onEdgesChange
  // ya que estamos usando directamente las funciones del store de Zustand
  
  const handleConnect = useCallback(
    (connection) => {
      try {
        // Usar la función onConnect del store para crear la conexión
        onConnect(connection);
        
        // Mostrar mensaje de éxito
        setByteMessage('✨ Conexión creada');
        setTimeout(() => setByteMessage(''), 3000);
        
        // Guardar las aristas en localStorage para recuperación
        backupEdgesToLocalStorage(edges);
        
        console.log('[TrainingScreen] Nueva conexión creada');
      } catch (error) {
        console.error('[TrainingScreen] Error al crear conexión:', error);
        setByteMessage('❌ Error al crear conexión: ' + (error.message || 'Error desconocido'));
        setTimeout(() => setByteMessage(''), 3000);
      }
    },
    [onConnect, edges, setByteMessage, backupEdgesToLocalStorage]
  );
  
  // Función para guardar el flujo con debounce
  const debouncedSave = useCallback(
    debounce(() => {
      console.log('[TrainingScreen] Guardando flujo con debounce...');
      handleSaveFlow();
    }, 2000),
    [handleSaveFlow]
  );
  
  // Nota: Ya no necesitamos definir setFlowName aquí
  // ya que estamos usando directamente la función del store de Zustand
  
  // Forzar un re-renderizado completo si ocurre algún error
  useEffect(() => {
    const handleError = () => {
      console.log('[TrainingScreen] Forzando re-renderizado completo debido a un error');
      setTimeout(() => setRenderKey(Date.now()), 100);
    };
    
    window.addEventListener('unhandledrejection', handleError);
    window.addEventListener('error', handleError);
    
    return () => {
      window.removeEventListener('unhandledrejection', handleError);
      window.removeEventListener('error', handleError);
    };
  }, []);

  // Ya no necesitamos cargar los stores de manera segura
  // ya que los importamos directamente al inicio del archivo
  
  // Verificar si el componente está listo para renderizarse
  useEffect(() => {
    // Marcar el componente como listo después de que se hayan cargado todos los datos necesarios
    setIsComponentReady(true);
  }, []);
  
  // Si el componente no está listo, mostrar un mensaje de carga
    return (
      <div className="ts-loading-screen">
        <img src={logo} alt="Logo" className="ts-loading-logo" />
        <h2>Inicializando editor de flujo...</h2>
        <div className="ts-loading-spinner"></div>
        <p>Cargando componentes esenciales...</p>
      </div>
    );
  }
  
  // Verificar que todas las dependencias críticas estén disponibles antes de renderizar
  useEffect(() => {
    // Lista de funciones críticas que deben estar disponibles
    const criticalFunctions = [
      { name: 'analyzeFlow', fn: analyzeFlow },
      { name: 'generateSuggestions', fn: generateSuggestions },
      { name: 'handleSaveFlow', fn: handleSaveFlow },
      { name: 'undo', fn: undo },
      { name: 'redo', fn: redo },
      { name: 'toggleUltraMode', fn: toggleUltraMode },
      { name: 'toggleSimulation', fn: toggleSimulation },
      { name: 'setShowTemplateSelector', fn: setShowTemplateSelector },
      { name: 'setShowExportMode', fn: setShowExportMode },
      { name: 'setShowConnectionEditor', fn: setShowConnectionEditor },
      { name: 'setShowRouteAnalysis', fn: setShowRouteAnalysis },
      { name: 'setShowVersionHistoryPanel', fn: setShowVersionHistoryPanel },
      { name: 'setShowSuggestionsModal', fn: setShowSuggestionsModal },
      { name: 'setShowEmbedModal', fn: setShowEmbedModal },
      { name: 'setSelectedConnection', fn: setSelectedConnection },
      { name: 'setConnectionProperties', fn: setConnectionProperties },
      { name: 'handleSelectTemplate', fn: handleSelectTemplate }
    ];
    
    // Verificar si todas las funciones críticas están disponibles
    const missingFunctions = criticalFunctions.filter(item => {
      return typeof item.fn !== 'function';
    });
    
    if (missingFunctions.length > 0) {
      console.error('[TrainingScreen] Funciones críticas no disponibles:', 
        missingFunctions.map(f => f.name));
      setIsComponentReady(false);
    } else {
      console.log('[TrainingScreen] Todas las funciones críticas están disponibles, componente listo para renderizar');
      setIsComponentReady(true);
    }
  }, [analyzeFlow, generateSuggestions, handleSaveFlow, undo, redo, 
      toggleUltraMode, toggleSimulation, setShowTemplateSelector, 
      setShowExportMode, setShowConnectionEditor, setShowRouteAnalysis, 
      setShowVersionHistoryPanel, setShowSuggestionsModal, setShowEmbedModal, 
      setSelectedConnection, setConnectionProperties, handleSelectTemplate]);
  
  // Si el componente no está listo, mostrar un estado de carga
  if (!isComponentReady) {
    return (
      <div className="ts-loading-screen">
        <img src={logo} alt="Logo" className="ts-loading-logo" />
        <h2>Inicializando editor de flujo...</h2>
        <div className="ts-loading-spinner"></div>
        <p>Cargando componentes y funcionalidades...</p>
      </div>
    );
  }
  
  // Renderizar el componente solo cuando todas las dependencias estén disponibles
  return (
    <div className="training-screen">
      <div className="flow-container">
        <FlowEditor
          nodes={nodes}
          edges={edges}
          onNodesChange={onNodesChange}
          onEdgesChange={onEdgesChange}
          onConnect={onConnect}
          onSave={handleSaveFlow}
          onDebouncedSave={debouncedSave}
          flowName={flowName}
          onFlowNameChange={setFlowName}
          isSaving={isLoading}
          error={error}
          plubotId={plubotData?.id || plubotIdFromUrl}
        />
      </div>
      
      <NodePalette />
      
      {/* Usar funciones de manera segura con comprobaciones adicionales */}
      <ByteAssistant 
        onAnalyze={typeof analyzeFlow === 'function' ? analyzeFlow : () => console.warn('analyzeFlow no disponible')}
        onSuggest={typeof generateSuggestions === 'function' ? generateSuggestions : () => console.warn('generateSuggestions no disponible')}
        onSave={typeof handleSaveFlow === 'function' ? handleSaveFlow : () => console.warn('handleSaveFlow no disponible')}
        onUndo={typeof canUndo === 'function' && canUndo() && typeof undo === 'function' ? undo : null}
        onRedo={typeof canRedo === 'function' && canRedo() && typeof redo === 'function' ? redo : null}
        onToggleUltraMode={typeof toggleUltraMode === 'function' ? toggleUltraMode : () => console.warn('toggleUltraMode no disponible')}
        isUltraMode={Boolean(isUltraMode)}
        byteMessage={byteMessage || ''}
      />
      
      <StatusBubble 
        showSimulation={Boolean(showSimulation)}
        onToggleSimulation={typeof toggleSimulation === 'function' ? toggleSimulation : () => console.warn('toggleSimulation no disponible')}
        onShowTemplates={typeof setShowTemplateSelector === 'function' ? () => setShowTemplateSelector(true) : () => console.warn('setShowTemplateSelector no disponible')}
        onShowExport={typeof setShowExportMode === 'function' ? () => setShowExportMode(true) : () => console.warn('setShowExportMode no disponible')}
        onShowConnections={typeof setShowConnectionEditor === 'function' ? () => setShowConnectionEditor(true) : () => console.warn('setShowConnectionEditor no disponible')}
        onShowRouteAnalysis={typeof setShowRouteAnalysis === 'function' ? () => setShowRouteAnalysis(true) : () => console.warn('setShowRouteAnalysis no disponible')}
        onShowVersionHistory={typeof setShowVersionHistoryPanel === 'function' ? () => setShowVersionHistoryPanel(true) : () => console.warn('setShowVersionHistoryPanel no disponible')}
        onShowSuggestions={typeof setShowSuggestionsModal === 'function' ? () => setShowSuggestionsModal(true) : () => console.warn('setShowSuggestionsModal no disponible')}
        onShowEmbed={typeof setShowEmbedModal === 'function' ? () => setShowEmbedModal(true) : () => console.warn('setShowEmbedModal no disponible')}
      />
      
      {/* Modales con comprobaciones de seguridad adicionales */}
      <ModalManager 
        modals={{
          showTemplateSelector: Boolean(showTemplateSelector),
          showExportMode: Boolean(showExportMode),
          showConnectionEditor: Boolean(showConnectionEditor),
          showRouteAnalysis: Boolean(showRouteAnalysis),
          showVersionHistoryPanel: Boolean(showVersionHistoryPanel),
          showSuggestionsModal: Boolean(showSuggestionsModal),
          showEmbedModal: Boolean(showEmbedModal)
        }}
        modalProps={{
          templateSelector: {
            onSelectTemplate: typeof handleSelectTemplate === 'function' ? handleSelectTemplate : () => console.warn('handleSelectTemplate no disponible')
          },
          importExport: {
            importData: importData || '',
            exportFormat: exportFormat || 'json',
            onImport: typeof handleImportFromStore === 'function' ? handleImportFromStore : () => console.warn('handleImportFromStore no disponible'),
            onExport: typeof handleExportFromStore === 'function' ? handleExportFromStore : () => console.warn('handleExportFromStore no disponible'),
            onImportDataChange: typeof setImportData === 'function' ? setImportData : () => console.warn('setImportData no disponible'),
            onExportFormatChange: typeof setExportFormat === 'function' ? setExportFormat : () => console.warn('setExportFormat no disponible')
          },
          connectionEditor: {
            connection: selectedConnection || null,
            properties: connectionProperties || {},
            onUpdate: (updatedProps) => {
              if (selectedConnection && typeof setConnectionProperties === 'function') {
                setConnectionProperties(updatedProps);
              } else {
                console.warn('No se puede actualizar propiedades de conexión');
              }
            },
            onClose: typeof setSelectedConnection === 'function' ? () => setSelectedConnection(null) : () => console.warn('setSelectedConnection no disponible')
          },
          routeAnalysis: {
            data: routeAnalysisData || null,
            onClose: typeof setShowRouteAnalysis === 'function' ? () => setShowRouteAnalysis(false) : () => console.warn('setShowRouteAnalysis no disponible')
          },
          versionHistory: {
            plubotId: plubotData?.id || plubotIdFromUrl,
            onClose: typeof setShowVersionHistoryPanel === 'function' ? () => setShowVersionHistoryPanel(false) : () => console.warn('setShowVersionHistoryPanel no disponible')
          },
          suggestionsModal: {
            suggestions: nodeSuggestions || [],
            onApplySuggestion: (suggestion) => {
              console.log('Aplicar sugerencia:', suggestion);
              if (typeof setShowSuggestionsModal === 'function') {
                setShowSuggestionsModal(false);
              }
            },
            onClose: typeof setShowSuggestionsModal === 'function' ? () => setShowSuggestionsModal(false) : () => console.warn('setShowSuggestionsModal no disponible')
          },
          embedModal: {
            plubotId: plubotData?.id || plubotIdFromUrl,
            onClose: typeof setShowEmbedModal === 'function' ? () => setShowEmbedModal(false) : () => console.warn('setShowEmbedModal no disponible')
          }
        }}
        onClose={(modalName) => {
          switch (modalName) {
            case 'showTemplateSelector':
              if (typeof setShowTemplateSelector === 'function') setShowTemplateSelector(false);
              break;
            case 'showExportMode':
              if (typeof setShowExportMode === 'function') setShowExportMode(false);
              break;
            case 'showConnectionEditor':
              if (typeof setShowConnectionEditor === 'function') setShowConnectionEditor(false);
              break;
            case 'showRouteAnalysis':
              if (typeof setShowRouteAnalysis === 'function') setShowRouteAnalysis(false);
              break;
            case 'showVersionHistoryPanel':
              if (typeof setShowVersionHistoryPanel === 'function') setShowVersionHistoryPanel(false);
              break;
            case 'showSuggestionsModal':
              if (typeof setShowSuggestionsModal === 'function') setShowSuggestionsModal(false);
              break;
            case 'showEmbedModal':
              if (typeof setShowEmbedModal === 'function') setShowEmbedModal(false);
              break;
            default:
              break;
          }
        }}
      />
    </div>
  );
};

// Componente envoltorio seguro que evita errores de inicialización
const ErrorBoundary = ({ children }) => {
  // Crear un componente ErrorBoundary personalizado si no está disponible globalmente
  const [hasError, setHasError] = useState(false);
  const [error, setError] = useState(null);

  useEffect(() => {
    // Función para manejar errores no capturados
    const handleError = (event) => {
      console.error('[ErrorBoundary] Error no capturado:', event.error);
      setHasError(true);
      setError(event.error);
    };

    // Agregar listener para errores no capturados
    window.addEventListener('error', handleError);

    // Limpiar listener al desmontar
    return () => {
      window.removeEventListener('error', handleError);
    };
  }, []);

  if (hasError) {
    return (
      <div className="error-boundary">
        <h2>Algo salió mal</h2>
        <p>{error?.message || 'Error desconocido'}</p>
        <button onClick={() => window.location.reload()}>Recargar página</button>
      { name: 'setShowExportMode', fn: setShowExportMode },
      { name: 'setShowConnectionEditor', fn: setShowConnectionEditor },
      { name: 'setShowRouteAnalysis', fn: setShowRouteAnalysis },
      { name: 'setShowVersionHistoryPanel', fn: setShowVersionHistoryPanel },
      { name: 'setShowSuggestionsModal', fn: setShowSuggestionsModal },
      { name: 'setShowEmbedModal', fn: setShowEmbedModal },
      { name: 'setSelectedConnection', fn: setSelectedConnection },
      { name: 'setConnectionProperties', fn: setConnectionProperties },
      { name: 'handleSelectTemplate', fn: handleSelectTemplate }
    ];
    
    // Verificar si todas las funciones críticas están disponibles
    const missingFunctions = criticalFunctions.filter(item => {
      return typeof item.fn !== 'function';
    });
    
    if (missingFunctions.length > 0) {
      console.error('[TrainingScreen] Funciones críticas no disponibles:', 
        missingFunctions.map(f => f.name));
      setIsComponentReady(false);
    } else {
      console.log('[TrainingScreen] Todas las funciones críticas están disponibles, componente listo para renderizar');
      setIsComponentReady(true);
    }
  }, [analyzeFlow, generateSuggestions, handleSaveFlow, undo, redo, 
      toggleUltraMode, toggleSimulation, setShowTemplateSelector, 
      setShowExportMode, setShowConnectionEditor, setShowRouteAnalysis, 
      setShowVersionHistoryPanel, setShowSuggestionsModal, setShowEmbedModal, 
      setSelectedConnection, setConnectionProperties, handleSelectTemplate]);
  
  // Si el componente no está listo, mostrar un estado de carga
  if (!isComponentReady) {
    return (
      <div className="ts-loading-screen">
        <img src={logo} alt="Logo" className="ts-loading-logo" />
        <h2>Inicializando editor de flujo...</h2>
        <div className="ts-loading-spinner"></div>
        <p>Cargando componentes y funcionalidades...</p>
      </div>
    );
  }
  
  // Renderizar el componente solo cuando todas las dependencias estén disponibles
  return (
    <div className="training-screen">
      <div className="flow-container">
        <FlowEditor
          nodes={nodes}
          edges={edges}
          onNodesChange={onNodesChange}
          onEdgesChange={onEdgesChange}
          onConnect={onConnect}
          onSave={handleSaveFlow}
          onDebouncedSave={debouncedSave}
          flowName={flowName}
          onFlowNameChange={setFlowName}
          isSaving={isLoading}
          error={error}
          plubotId={plubotData?.id || plubotIdFromUrl}
        />
      </div>
      
      <NodePalette />
      
      {/* Usar funciones de manera segura con comprobaciones adicionales */}
      <ByteAssistant 
        onAnalyze={typeof analyzeFlow === 'function' ? analyzeFlow : () => console.warn('analyzeFlow no disponible')}
        onSuggest={typeof generateSuggestions === 'function' ? generateSuggestions : () => console.warn('generateSuggestions no disponible')}
        onSave={typeof handleSaveFlow === 'function' ? handleSaveFlow : () => console.warn('handleSaveFlow no disponible')}
        onUndo={typeof canUndo === 'function' && canUndo() && typeof undo === 'function' ? undo : null}
        onRedo={typeof canRedo === 'function' && canRedo() && typeof redo === 'function' ? redo : null}
        onToggleUltraMode={typeof toggleUltraMode === 'function' ? toggleUltraMode : () => console.warn('toggleUltraMode no disponible')}
        isUltraMode={Boolean(isUltraMode)}
        byteMessage={byteMessage || ''}
      />
      
      <StatusBubble 
        showSimulation={Boolean(showSimulation)}
        onToggleSimulation={typeof toggleSimulation === 'function' ? toggleSimulation : () => console.warn('toggleSimulation no disponible')}
        onShowTemplates={typeof setShowTemplateSelector === 'function' ? () => setShowTemplateSelector(true) : () => console.warn('setShowTemplateSelector no disponible')}
        onShowExport={typeof setShowExportMode === 'function' ? () => setShowExportMode(true) : () => console.warn('setShowExportMode no disponible')}
        onShowConnections={typeof setShowConnectionEditor === 'function' ? () => setShowConnectionEditor(true) : () => console.warn('setShowConnectionEditor no disponible')}
        onShowRouteAnalysis={typeof setShowRouteAnalysis === 'function' ? () => setShowRouteAnalysis(true) : () => console.warn('setShowRouteAnalysis no disponible')}
        onShowVersionHistory={typeof setShowVersionHistoryPanel === 'function' ? () => setShowVersionHistoryPanel(true) : () => console.warn('setShowVersionHistoryPanel no disponible')}
        onShowSuggestions={typeof setShowSuggestionsModal === 'function' ? () => setShowSuggestionsModal(true) : () => console.warn('setShowSuggestionsModal no disponible')}
        onShowEmbed={typeof setShowEmbedModal === 'function' ? () => setShowEmbedModal(true) : () => console.warn('setShowEmbedModal no disponible')}
      />
      
      {/* Modales con comprobaciones de seguridad adicionales */}
      <ModalManager 
        modals={{
          showTemplateSelector: Boolean(showTemplateSelector),
          showExportMode: Boolean(showExportMode),
          showConnectionEditor: Boolean(showConnectionEditor),
          showRouteAnalysis: Boolean(showRouteAnalysis),
          showVersionHistoryPanel: Boolean(showVersionHistoryPanel),
          showSuggestionsModal: Boolean(showSuggestionsModal),
          showEmbedModal: Boolean(showEmbedModal)
        }}
        modalProps={{
          templateSelector: {
            onSelectTemplate: typeof handleSelectTemplate === 'function' ? handleSelectTemplate : () => console.warn('handleSelectTemplate no disponible')
          },
          importExport: {
            importData: importData || '',
            exportFormat: exportFormat || 'json',
            onImport: typeof handleImportFromStore === 'function' ? handleImportFromStore : () => console.warn('handleImportFromStore no disponible'),
            onExport: typeof handleExportFromStore === 'function' ? handleExportFromStore : () => console.warn('handleExportFromStore no disponible'),
            onImportDataChange: typeof setImportData === 'function' ? setImportData : () => console.warn('setImportData no disponible'),
            onExportFormatChange: typeof setExportFormat === 'function' ? setExportFormat : () => console.warn('setExportFormat no disponible')
          },
          connectionEditor: {
            connection: selectedConnection || null,
            properties: connectionProperties || {},
            onUpdate: (updatedProps) => {
              if (selectedConnection && typeof setConnectionProperties === 'function') {
                setConnectionProperties(updatedProps);
              } else {
                console.warn('No se puede actualizar propiedades de conexión');
              }
            },
            onClose: typeof setSelectedConnection === 'function' ? () => setSelectedConnection(null) : () => console.warn('setSelectedConnection no disponible')
          },
          routeAnalysis: {
            data: routeAnalysisData || null,
            onClose: typeof setShowRouteAnalysis === 'function' ? () => setShowRouteAnalysis(false) : () => console.warn('setShowRouteAnalysis no disponible')
          },
          versionHistory: {
            plubotId: plubotData?.id || plubotIdFromUrl,
            onClose: typeof setShowVersionHistoryPanel === 'function' ? () => setShowVersionHistoryPanel(false) : () => console.warn('setShowVersionHistoryPanel no disponible')
          },
          suggestionsModal: {
            suggestions: nodeSuggestions || [],
            onApplySuggestion: (suggestion) => {
              console.log('Aplicar sugerencia:', suggestion);
              if (typeof setShowSuggestionsModal === 'function') {
                setShowSuggestionsModal(false);
              }
            },
            onClose: typeof setShowSuggestionsModal === 'function' ? () => setShowSuggestionsModal(false) : () => console.warn('setShowSuggestionsModal no disponible')
          },
          embedModal: {
            plubotId: plubotData?.id || plubotIdFromUrl,
            onClose: typeof setShowEmbedModal === 'function' ? () => setShowEmbedModal(false) : () => console.warn('setShowEmbedModal no disponible')
          }
        }}
        onClose={(modalName) => {
          switch (modalName) {
            case 'showTemplateSelector':
              if (typeof setShowTemplateSelector === 'function') setShowTemplateSelector(false);
              break;
            case 'showExportMode':
              if (typeof setShowExportMode === 'function') setShowExportMode(false);
              break;
            case 'showConnectionEditor':
              if (typeof setShowConnectionEditor === 'function') setShowConnectionEditor(false);
              break;
            case 'showRouteAnalysis':
              if (typeof setShowRouteAnalysis === 'function') setShowRouteAnalysis(false);
              break;
            case 'showVersionHistoryPanel':
              if (typeof setShowVersionHistoryPanel === 'function') setShowVersionHistoryPanel(false);
              break;
            case 'showSuggestionsModal':
              if (typeof setShowSuggestionsModal === 'function') setShowSuggestionsModal(false);
              break;
            case 'showEmbedModal':
              if (typeof setShowEmbedModal === 'function') setShowEmbedModal(false);
              break;
            default:
              break;
          }
        }}
      />
    </div>
  );
};


// Crear un componente ErrorBoundary personalizado si no está disponible globalmente
class ErrorBoundary extends React.Component {
  constructor(props) {
    super(props);
    this.state = { hasError: false, error: null };
  }

  static getDerivedStateFromError(error) {
    return { hasError: true, error };
  }

  componentDidCatch(error, errorInfo) {
    console.error('[ErrorBoundary] Error capturado:', error, errorInfo);
  }

  render() {
    if (this.state.hasError) {
      return this.props.fallback || (
        <div className="error-boundary-fallback">
          <h2>Algo salió mal.</h2>
          <p>{this.state.error?.message || 'Error desconocido'}</p>
          <button onClick={() => window.location.reload()}>Recargar página</button>
        </div>
      );
    }

    return this.props.children;
  }
}

// Exportar el componente envoltorio seguro
export default SafeTrainingScreen;
